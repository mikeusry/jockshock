---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Overview" activeNav="/admin/">
  <h1 style="font-size: 28px; margin-bottom: 8px;">JockShock Admin</h1>
  <p style="color: var(--text-secondary); margin-bottom: 32px; max-width: 60ch;">
    Internal pages. Not crawlable. Sessions persist for the browser tab; close the tab to log out.
  </p>

  <h2 style="font-size: 13px; text-transform: uppercase; letter-spacing: 0.14em; color: var(--text-secondary); margin-bottom: 12px;">
    Pages
  </h2>

  <ul style="list-style: none; padding: 0;">
    <li style="padding: 16px; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); margin-bottom: 12px;">
      <a href="/admin/fred/" style="font-weight: 700; font-size: 16px;">Fred — Founder Plan</a>
      <p style="color: var(--text-secondary); font-size: 14px; margin-top: 4px;">
        Commission structure, product economics, gym channel program. Athlete-to-founder voice.
      </p>
    </li>
  </ul>
</AdminLayout>
