---
/**
 * /label — bottle QR landing page.
 *
 * The QR printed on the 32oz bottle resolves here:
 *   /label?utm_source=label&utm_medium=qr&utm_campaign=jockshock-label&utm_content=product-label
 *
 * Audience: someone holding the bottle. They already bought it. Three jobs,
 * in priority order:
 *   1. How to use it (they just got it, want quick directions)
 *   2. Reorder (repeat purchase — drives LTV, not first conversion)
 *   3. Email capture (gear-care drops + restock reminders via Klaviyo)
 *
 * Mobile-first. Most scans will be on a phone, in a locker room or trunk.
 * Keep it short. No marketing fluff — they already converted.
 *
 * UTM/pixel: BaseLayout's point.dog pixel auto-stamps sub_brand=jockshock and
 * captures UTMs on the page-view event, so we don't fire a custom event here.
 * Label-scan attribution is the (utm_source=label, utm_medium=qr) tuple.
 *
 * Klaviyo: reuses /api/lead-magnet with source=jockshock-bottle-label-qr so
 * scanners land in their own segment. List ID + welcome flow already wired.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import StepBadge from "../components/StepBadge.astro";

const title = "Welcome to JockShock — How to Use Your Bottle";
const description =
  "You scanned the bottle. Here's the 60-second routine, plus reorder and gear-care tips. Powered by ZeroPoint Technology.";

const HERO_BOTTLE =
  "https://res.cloudinary.com/southland-organics/image/upload/c_fit,w_560,q_auto,f_auto,dpr_auto/JockShock/jockshock-32oz-single-2026.png";
---

<BaseLayout title={title} description={description}>
  <main class="js-label">
    {/* HERO — confirm they're in the right place */}
    <section class="hero">
      <div class="hero-inner">
        <p class="eyebrow">You scanned the bottle.</p>
        <h1>You're in the right place.</h1>
        <p class="sub">
          Quick directions, reorder, and gear-care drops — all below.
          Powered by ZeroPoint Technology.
        </p>
        <img class="hero-bottle" src={HERO_BOTTLE} alt="JockShock 32oz" />
      </div>
    </section>

    {/* HOW TO USE — the #1 reason someone scans */}
    <section class="routine">
      <div class="routine-inner">
        <p class="eyebrow">60-second routine</p>
        <h2>Spray. Air. Done.</h2>
        <p class="sub">
          Works best as a habit, not a rescue mission. A minute after practice
          keeps your gear, your bag, and your car from turning into a
          hockey-bag horror show.
        </p>
        <ol class="steps">
          <li>
            <StepBadge number="1" tone="yellow" size={56} class="step-badge" />
            <h3>Spray</h3>
            <p>Inside the pads. Inside the helmet. Inside the bag. Saturate, don't mist.</p>
          </li>
          <li>
            <StepBadge number="2" tone="yellow" size={56} class="step-badge" />
            <h3>Air</h3>
            <p>Two minutes. Hang it if you can.</p>
          </li>
          <li>
            <StepBadge number="3" tone="yellow" size={56} class="step-badge" />
            <h3>Done</h3>
            <p>Tomorrow's practice doesn't smell like yesterday's.</p>
          </li>
        </ol>
        <p class="routine-note">
          For shoes and cleats: spray the inside, leave them open overnight.
          For gear bags: spray the empty bag at the end of the week.
        </p>
      </div>
    </section>

    {/* REORDER */}
    <section class="reorder">
      <div class="reorder-inner">
        <p class="eyebrow">Running low?</p>
        <h2>Get your next bottle.</h2>
        <p class="sub">
          A 32oz lasts most athletes 6–10 weeks of heavy use. Reorder before
          you run out — gear funk is easier to prevent than to undo.
        </p>
        <a href="/products/jockshock/" class="cta-primary">Reorder JockShock</a>
        <a href="/" class="cta-secondary">See packs &amp; pricing</a>
      </div>
    </section>

    {/* KLAVIYO CAPTURE */}
    <section class="optin">
      <div class="optin-inner">
        <p class="eyebrow">Want gear-care drops?</p>
        <h2>One short email a month. No spam.</h2>
        <p class="sub">
          Restock reminders, gear-care tips, and first-dibs on new sizes and
          team programs. Unsubscribe in one click.
        </p>
        <form id="label-optin" class="optin-form" novalidate>
          <label class="visually-hidden" for="label-email">Email address</label>
          <input
            type="email"
            id="label-email"
            name="email"
            required
            autocomplete="email"
            inputmode="email"
            placeholder="you@email.com"
          />
          {/* honeypot */}
          <input
            type="text"
            name="company_website"
            class="visually-hidden"
            tabindex="-1"
            autocomplete="off"
            aria-hidden="true"
          />
          <button type="submit">Sign me up</button>
          <p class="optin-status" role="status" aria-live="polite"></p>
        </form>
      </div>
    </section>

    {/* HELP */}
    <section class="help">
      <div class="help-inner">
        <h2>Questions about your bottle?</h2>
        <p>
          Common ones — what gear it's safe on, why a 32oz, what's in it — are
          answered on the homepage FAQ.
        </p>
        <a href="/#faq" class="cta-secondary">See the FAQ</a>
      </div>
    </section>
  </main>

  <script is:inline>
    (function () {
      const form = document.getElementById("label-optin");
      if (!form) return;
      const status = form.querySelector(".optin-status");

      form.addEventListener("submit", async function (e) {
        e.preventDefault();
        const fd = new FormData(form);
        const email = String(fd.get("email") || "").trim();
        const honey = String(fd.get("company_website") || "").trim();
        if (!email) {
          status.textContent = "Enter an email.";
          return;
        }
        status.textContent = "Signing you up…";
        try {
          const res = await fetch("/api/lead-magnet", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              email: email,
              company_website: honey,
              source: "jockshock-bottle-label-qr",
              persona: "aaron",
            }),
          });
          if (res.ok) {
            status.textContent = "You're in. Check your inbox.";
            form.querySelector("input[type=email]").value = "";
          } else {
            status.textContent = "Something went wrong. Try again in a minute.";
          }
        } catch (_err) {
          status.textContent = "Network error. Try again in a minute.";
        }
      });
    })();
  </script>

  <style>
    /* Light/dark rhythm matches the rest of the site:
       hero (dark) → routine (light) → reorder (dark) → optin (light) → help (yellow). */
    .js-label { display: block; }
    .visually-hidden {
      position: absolute !important;
      width: 1px; height: 1px;
      padding: 0; margin: -1px;
      overflow: hidden; clip: rect(0,0,0,0);
      white-space: nowrap; border: 0;
    }

    section { padding: 56px 20px; }
    .hero-inner, .routine-inner, .reorder-inner, .optin-inner, .help-inner {
      max-width: 720px;
      margin: 0 auto;
      text-align: center;
    }
    .eyebrow {
      font-family: "Bebas Neue", sans-serif;
      letter-spacing: 0.18em;
      color: var(--athletic-safety-yellow);
      font-size: 14px;
      margin: 0 0 12px;
      text-transform: uppercase;
    }
    h1, h2 {
      font-family: "Bebas Neue", sans-serif;
      letter-spacing: 0.02em;
      line-height: 1.05;
      margin: 0 0 16px;
    }
    h1 { font-size: clamp(40px, 8vw, 64px); }
    h2 { font-size: clamp(32px, 6vw, 48px); }
    .sub { font-size: 17px; line-height: 1.5; margin: 0 0 24px; opacity: 0.92; }

    /* HERO — dark */
    .hero {
      background: var(--tactical-black, #0d0d0d);
      color: var(--performance-white, #fafafa);
    }
    .hero-bottle {
      max-width: 240px;
      width: 60%;
      height: auto;
      margin: 12px auto 0;
      display: block;
    }

    /* ROUTINE — light */
    .routine { background: #f6f6f4; color: #0d0d0d; }
    .routine .eyebrow { color: #0d0d0d; }
    .steps {
      list-style: none;
      padding: 0;
      margin: 24px 0 16px;
      display: grid;
      gap: 24px;
      grid-template-columns: 1fr;
    }
    @media (min-width: 720px) {
      .steps { grid-template-columns: repeat(3, 1fr); }
    }
    .steps li {
      background: #fff;
      border-radius: 10px;
      padding: 28px 20px;
      box-shadow: 0 1px 0 rgba(0,0,0,0.06);
      text-align: center;
    }
    .steps h3 {
      font-family: "Bebas Neue", sans-serif;
      font-size: 24px;
      margin: 12px 0 6px;
      letter-spacing: 0.04em;
    }
    .steps p { margin: 0; font-size: 15px; line-height: 1.5; }
    .step-badge { margin: 0 auto 4px; display: block; }
    .routine-note {
      font-size: 14px;
      opacity: 0.75;
      margin-top: 16px;
    }

    /* REORDER — dark */
    .reorder {
      background: var(--tactical-black, #0d0d0d);
      color: var(--performance-white, #fafafa);
    }
    .cta-primary, .cta-secondary {
      display: inline-block;
      padding: 14px 24px;
      font-family: "Bebas Neue", sans-serif;
      font-size: 18px;
      letter-spacing: 0.06em;
      text-decoration: none;
      border-radius: 6px;
      margin: 6px 6px 0;
      transition: transform 0.1s ease, opacity 0.1s ease;
    }
    .cta-primary {
      background: var(--athletic-safety-yellow, #ffe500);
      color: #0d0d0d;
    }
    .cta-secondary {
      background: transparent;
      color: var(--performance-white, #fafafa);
      border: 1px solid rgba(255,255,255,0.4);
    }
    .reorder .cta-primary:hover, .reorder .cta-secondary:hover { transform: translateY(-1px); }

    /* OPTIN — light */
    .optin { background: #fafafa; color: #0d0d0d; }
    .optin .eyebrow { color: #0d0d0d; }
    .optin-form {
      display: grid;
      gap: 10px;
      max-width: 420px;
      margin: 0 auto;
    }
    .optin-form input[type="email"] {
      padding: 14px 16px;
      font-size: 16px;
      border: 1px solid #d4d4d4;
      border-radius: 6px;
      background: #fff;
      color: #0d0d0d;
    }
    .optin-form button {
      padding: 14px 16px;
      font-family: "Bebas Neue", sans-serif;
      font-size: 18px;
      letter-spacing: 0.06em;
      background: #0d0d0d;
      color: var(--athletic-safety-yellow, #ffe500);
      border: none;
      border-radius: 6px;
      cursor: pointer;
    }
    .optin-form button:hover { opacity: 0.92; }
    .optin-status {
      min-height: 1.2em;
      font-size: 14px;
      margin: 4px 0 0;
      opacity: 0.85;
    }

    /* HELP — yellow accent */
    .help {
      background: var(--athletic-safety-yellow, #ffe500);
      color: #0d0d0d;
    }
    .help h2 { color: #0d0d0d; }
    .help p { font-size: 16px; max-width: 560px; margin: 0 auto 16px; }
    .help .cta-secondary {
      color: #0d0d0d;
      border-color: rgba(0,0,0,0.5);
    }
  </style>
</BaseLayout>
