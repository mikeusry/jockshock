};

const FAQ_LD = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: FAQ_ITEMS.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: { "@type": "Answer", text: item.a },
  })),
};
---

<BaseLayout title={title} description={description} jsonLd={[ARTICLE_LD, FAQ_LD]}>
  <div class="js-learn">
