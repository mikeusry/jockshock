        <p class="faq-crosslink">
          Still wondering why it happens at all? Read <a
            href="/learn/why-do-my-feet-smell/">why feet smell in the first place</a
          >.
        </p>
      </div>
    </section>

    <!-- TIERS / CTA -->
    <section class="tiers">
      <div class="tiers-inner">
        <p class="section-eyebrow">Get yours</p>
