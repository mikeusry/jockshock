---
/**
 * JockShock homepage. Aaron voice (per brand-brief.md). No unsubstantiated
 * claims. CTAs route to /products/jockshock for the actual buy path. Uses
 * BaseLayout so the point.dog pixel + cart drawer fire on this page.
 */
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "JockShock — Pro-Grade Equipment Deodorizer for Serious Athletes";
const description =
  "Pro-grade gear deodorizer. EPA-registered HOCl chemistry. Built for athletic gear, not for the kitchen. 32oz matte-black bottle, made in USA.";

const HERO_BG =
  "https://res.cloudinary.com/southland-organics/image/upload/JockShock/beckham2_t9b1zk.jpg";
const HERO_BOTTLE =
  "https://res.cloudinary.com/southland-organics/image/upload/c_fit,w_900,q_auto,f_auto/JockShock/jockshock-32oz-single-2026.png";
---

<BaseLayout title={title} description={description}>
  <div class="js-home">
    <!-- HERO -->
    <section class="hero">
      <div class="hero-bg" style={`background-image: url('${HERO_BG}')`}></div>
      <div class="hero-overlay"></div>
      <div class="hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">Performance Protection for Serious Athletes</p>
          <h1 class="hero-headline">
            Built for the locker room.<br />Not for the laundry room.
          </h1>
          <p class="hero-sub">
            JockShock is a pro-grade equipment deodorizer engineered for the
            gear athletes actually use. Hypochlorous acid chemistry. EPA-registered.
            No fragrance, no masking — just gear that doesn't reek when you open
            the bag.
          </p>
          <div class="hero-cta-row">
            <a href="/products/jockshock/" class="cta-primary">Get JockShock</a>
            <a href="#how" class="cta-secondary">How it works</a>
          </div>
          <ul class="hero-trust">
            <li>EPA-registered</li>
            <li>Built by D1 athletes</li>
            <li>Made in USA</li>
          </ul>
        </div>
        <div class="hero-product">
          <img src={HERO_BOTTLE} alt="JockShock 32oz pro-grade equipment deodorizer" />
        </div>
      </div>
    </section>

    <!-- THE MECHANISM -->
    <section class="mechanism" id="how">
      <div class="mechanism-inner">
        <p class="section-eyebrow">The mechanism</p>
        <h2 class="section-headline">
          Hypochlorous acid. The same chemistry your immune system makes.
        </h2>
        <p class="section-sub">
          Most "gear sprays" mask smell with fragrance. JockShock kills the
          bacteria producing the smell. HOCl is the molecule your own white
          blood cells use to fight infection — fast-acting, gear-safe, and
          residue-free at use concentration. EPA-registered as an antimicrobial.
        </p>

        <div class="mech-grid">
          <div class="mech-card">
            <h3>Kills the source</h3>
            <p>
              Targets the odor-causing bacteria in pads, helmets, gloves, mats,
              cleats, mouthguards. Not perfume.
            </p>
          </div>
          <div class="mech-card">
            <h3>Gear-safe materials</h3>
            <p>
              Engineered for foam, leather, mesh, padding, plastic — what your
              athletic equipment is actually made of. Won't damage gear.
            </p>
          </div>
          <div class="mech-card">
            <h3>Skin-safe contact</h3>
            <p>
              Same chemistry family as wound-care saline sprays. Safe on
              mouthguards, headgear, contact-area gear at use concentration.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ROUTINE -->
    <section class="routine">
      <div class="routine-inner">
        <p class="section-eyebrow">The routine</p>
        <h2 class="section-headline">
          Spray after every practice. The funk never sets in.
        </h2>
        <p class="section-sub">
          JockShock works best as a routine — not a rescue mission. 60 seconds
          after practice keeps your gear, your bag, and your car from turning
          into a hockey-bag horror show.
        </p>
        <ol class="steps">
          <li>
            <span class="step-num">1</span>
            <h3>Spray</h3>
            <p>Inside the pads. Inside the helmet. Inside the bag.</p>
          </li>
          <li>
            <span class="step-num">2</span>
            <h3>Air</h3>
            <p>Two minutes. Hang it if you can.</p>
          </li>
          <li>
            <span class="step-num">3</span>
            <h3>Done</h3>
            <p>Pack it away. Tomorrow's practice doesn't smell like yesterday's.</p>
          </li>
        </ol>
      </div>
    </section>

    <!-- PRODUCT TIERS / CTA -->
    <section class="tiers">
      <div class="tiers-inner">
        <p class="section-eyebrow">Get yours</p>
        <h2 class="section-headline">One bottle. Three packs. No subscription required.</h2>

        <div class="tier-grid">
          <a href="/products/jockshock/?variant=single" class="tier">
            <div class="tier-label">Single</div>
            <div class="tier-detail">1 × 32oz</div>
            <div class="tier-price">$24.99</div>
            <div class="tier-bottom">Get it →</div>
          </a>
          <a href="/products/jockshock/?variant=athlete" class="tier featured">
            <span class="tier-badge">Most Popular</span>
            <div class="tier-label">Athlete Pack</div>
            <div class="tier-detail">3 × 32oz</div>
            <div class="tier-price">$59.99</div>
            <div class="tier-savings">Save $15</div>
            <div class="tier-bottom">Get it →</div>
          </a>
          <a href="/products/jockshock/?variant=team" class="tier">
            <div class="tier-label">Team Pack</div>
            <div class="tier-detail">6 × 32oz</div>
            <div class="tier-price">$99.99</div>
            <div class="tier-savings">Save $50</div>
            <div class="tier-bottom">Get it →</div>
          </a>
        </div>

        <div class="pivots">
          <div class="pivot">
            <p>
              <strong>Sports parent?</strong>
              You opened the trunk and gagged. Here's how to fix it.
              <a href="/parents/">For parents →</a>
            </p>
          </div>
          <div class="pivot">
            <p>
              <strong>Coaching a team or running a facility?</strong>
              Volume pricing for programs.
              <a href="/teams/">Get a team quote →</a>
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CREDENTIAL -->
    <section class="credential">
      <div class="credential-inner">
        <p class="section-eyebrow">Built by athletes</p>
        <h2 class="section-headline">
          We made the spray we wanted in our own bags.
        </h2>
        <p class="credential-body">
          JockShock is built by D1 athletes who got tired of the gear stink and
          tired of products that don't fix it. Bleach destroys pads. Household
          sprays just mask. The "cleaning aisle" deodorizers read like cleaning
          aisle deodorizers. So we built something different — pro-grade, made
          for gear, made in the USA.
        </p>
      </div>
    </section>

    <!-- 30-DAY GUARANTEE -->
    <section class="guarantee">
      <div class="guarantee-inner">
        <h2>30-day money-back guarantee.</h2>
        <p>
          Try a bottle. If it doesn't work for you, we'll refund it — keep
          what's left.
        </p>
        <a href="/products/jockshock/" class="cta-primary">Get JockShock</a>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  // Aaron is the JockShock default — if no other signal stamped a persona,
  // stamp Aaron. Existing cookie wins (don't overwrite a Pam/Carmen visitor
  // who clicked back to the homepage).
  import { setPersonaIfMissing } from "../utils/persona-stamp";
  setPersonaIfMissing("aaron");
</script>

<style>
  .js-home {
    --jockshock-black: #0a0a0a;
    --jockshock-yellow: #facc15;
    --jockshock-text: #f3f4f6;
    --jockshock-muted: #9ca3af;
    background: var(--jockshock-black);
    color: var(--jockshock-text);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
  }
  .js-home h1, .js-home h2, .js-home h3 {
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  /* === HERO === */
  .hero {
    position: relative;
    min-height: 88vh;
    overflow: hidden;
    color: #fff;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    z-index: 0;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(10, 10, 10, 0.96) 0%, rgba(10, 10, 10, 0.6) 100%);
    z-index: 1;
  }
  .hero-grid {
    position: relative;
    z-index: 2;
    max-width: 1400px;
    margin: 0 auto;
    padding: 100px 5% 80px;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 64px;
    align-items: center;
    min-height: 88vh;
  }
  .hero-copy { max-width: 640px; }
  .eyebrow {
    color: var(--jockshock-yellow);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-weight: 700;
    font-size: 0.8125rem;
    margin-bottom: 24px;
  }
  .hero-headline {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    line-height: 1.05;
    color: #fff;
    margin: 0 0 24px;
  }
  .hero-sub {
    font-size: 1.125rem;
    line-height: 1.55;
    color: #d1d5db;
    margin-bottom: 32px;
  }
  .hero-cta-row {
    display: flex;
    gap: 16px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }
  .cta-primary {
    display: inline-block;
    background: var(--jockshock-yellow);
    color: var(--jockshock-black);
    padding: 18px 36px;
    text-decoration: none;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.9375rem;
    transition: transform 0.1s ease, box-shadow 0.15s ease;
    border-radius: 4px;
  }
  .cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(250, 204, 21, 0.35);
  }
  .cta-secondary {
    display: inline-block;
    color: #fff;
    padding: 18px 24px;
    text-decoration: none;
    font-weight: 700;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 4px;
    transition: border-color 0.15s ease;
  }
  .cta-secondary:hover { border-color: var(--jockshock-yellow); }
  .hero-trust {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 16px 24px;
    flex-wrap: wrap;
    color: #d1d5db;
    font-size: 0.875rem;
  }
  .hero-trust li {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .hero-trust li::before {
    content: "✓";
    color: var(--jockshock-yellow);
    font-weight: 800;
  }
  .hero-product {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .hero-product img {
    max-width: 100%;
    height: auto;
    max-height: 600px;
    filter: drop-shadow(0 30px 60px rgba(0, 0, 0, 0.7));
  }

  /* === SECTIONS === */
  .section-eyebrow {
    color: var(--jockshock-yellow);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 700;
    font-size: 0.8125rem;
    margin-bottom: 12px;
  }
  .section-headline {
    font-size: clamp(2rem, 4vw, 3rem);
    color: #fff;
    margin: 0 0 16px;
    line-height: 1.15;
  }
  .section-sub {
    font-size: 1.125rem;
    color: var(--jockshock-muted);
    line-height: 1.6;
    margin-bottom: 56px;
    max-width: 720px;
  }

  /* === MECHANISM === */
  .mechanism { padding: 100px 5%; background: var(--jockshock-black); }
  .mechanism-inner { max-width: 1200px; margin: 0 auto; }
  .mech-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 32px;
  }
  .mech-card {
    background: #141414;
    padding: 32px;
    border-left: 3px solid var(--jockshock-yellow);
  }
  .mech-card h3 {
    color: var(--jockshock-yellow);
    font-size: 1.25rem;
    margin: 0 0 12px;
  }
  .mech-card p { color: var(--jockshock-text); line-height: 1.6; font-size: 0.95rem; margin: 0; }

  /* === ROUTINE === */
  .routine { padding: 100px 5%; background: #050505; }
  .routine-inner { max-width: 900px; margin: 0 auto; }
  .steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 32px;
  }
  .steps li {
    background: #141414;
    padding: 32px;
    text-align: center;
  }
  .steps h3 {
    color: #fff;
    font-size: 1.25rem;
    margin: 0 0 8px;
  }
  .steps p { color: var(--jockshock-muted); margin: 0; font-size: 0.95rem; }
  .step-num {
    display: inline-flex;
    width: 56px;
    height: 56px;
    background: var(--jockshock-yellow);
    color: var(--jockshock-black);
    border-radius: 50%;
    align-items: center;
    justify-content: center;
    font-weight: 900;
    font-size: 1.5rem;
    margin-bottom: 20px;
  }

  /* === TIERS === */
  .tiers { padding: 100px 5%; background: var(--jockshock-black); border-top: 1px solid rgba(255,255,255,0.06); }
  .tiers-inner { max-width: 1200px; margin: 0 auto; text-align: center; }
  .tiers-inner .section-sub { margin-left: auto; margin-right: auto; }
  .tier-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 24px;
    margin-top: 16px;
  }
  .tier {
    background: #141414;
    padding: 40px 32px;
    text-decoration: none;
    color: var(--jockshock-text);
    border: 2px solid transparent;
    border-radius: 4px;
    transition: transform 0.15s ease, border-color 0.15s ease, box-shadow 0.15s ease;
    position: relative;
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .tier:hover {
    border-color: var(--jockshock-yellow);
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.5);
  }
  .tier.featured {
    border-color: var(--jockshock-yellow);
    background: #1a1a1a;
    box-shadow: 0 0 0 1px var(--jockshock-yellow);
  }
  .tier-badge {
    position: absolute;
    top: -12px;
    right: 24px;
    background: var(--jockshock-yellow);
    color: var(--jockshock-black);
    padding: 4px 12px;
    border-radius: 999px;
    font-size: 0.6875rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .tier-label {
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 800;
    font-size: 1rem;
  }
  .tier-detail { color: var(--jockshock-muted); font-size: 0.875rem; }
  .tier-price { color: #fff; font-size: 2rem; font-weight: 900; margin-top: 8px; }
  .tier-savings { color: var(--jockshock-yellow); font-weight: 700; font-size: 0.8125rem; }
  .tier-bottom {
    margin-top: 16px;
    color: var(--jockshock-yellow);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.8125rem;
  }

  .pivots {
    margin-top: 56px;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
    text-align: left;
  }
  .pivot {
    padding: 24px;
    background: #141414;
    border-left: 3px solid var(--jockshock-yellow);
  }
  .pivot p { margin: 0; color: var(--jockshock-text); }
  .pivot strong { color: #fff; display: block; margin-bottom: 4px; }
  .pivot a {
    color: var(--jockshock-yellow);
    text-decoration: none;
    font-weight: 700;
    display: inline-block;
    margin-top: 8px;
  }
  .pivot a:hover { text-decoration: underline; }

  /* === CREDENTIAL === */
  .credential { padding: 100px 5%; background: #050505; }
  .credential-inner { max-width: 800px; margin: 0 auto; text-align: center; }
  .credential-body {
    color: var(--jockshock-muted);
    line-height: 1.7;
    font-size: 1.05rem;
  }

  /* === GUARANTEE === */
  .guarantee {
    padding: 100px 5%;
    background: var(--jockshock-black);
    border-top: 2px solid var(--jockshock-yellow);
    border-bottom: 2px solid var(--jockshock-yellow);
    text-align: center;
  }
  .guarantee-inner { max-width: 600px; margin: 0 auto; }
  .guarantee h2 {
    color: #fff;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    margin-bottom: 16px;
  }
  .guarantee p {
    color: var(--jockshock-muted);
    margin-bottom: 32px;
    font-size: 1.05rem;
    line-height: 1.6;
  }

  /* === RESPONSIVE === */
  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 32px;
      padding: 64px 5% 56px;
      min-height: auto;
    }
    .hero-product img { max-height: 400px; }
    .mechanism, .routine, .tiers, .credential, .guarantee {
      padding: 64px 5%;
    }
  }
</style>
