---
import '../styles/globals.css';
import CartDrawer from '../components/CartDrawer.svelte';
import CartIcon from '../components/CartIcon.svelte';
import JockShockBuyButton from '../components/JockShockBuyButton.svelte';
import { getProductByHandle } from '../utils/shopify';

const title = "JockShock | Clinical Strength Gear Protection";
const description = "Shock the Stink. Own Your Game. Clinical-strength odor elimination for athletic equipment.";

// Try to fetch the JockShock product. If it doesn't exist yet (Shopify product
// not created), the buttons fall back to "COMING SOON" and the hero shows the
// placeholder bottle.
const headers = Astro.request.headers;
const ip = headers.get("x-vercel-forwarded-for") || Astro.clientAddress;

let product: Awaited<ReturnType<typeof getProductByHandle>> | null = null;
try {
  product = await getProductByHandle({ handle: 'jockshock', buyerIP: ip });
} catch {
  product = null;
}

// Resolve a variant by its bottle-count. Matches title containing "1 Bottle",
// "3 Bottles", "6 Bottles" — case-insensitive. Returns null when no match so
// the corresponding button shows COMING SOON rather than silently selling the
// wrong pack.
function variantIdFor(count: 1 | 3 | 6): string | null {
  if (!product?.variants?.nodes?.length) return null;
  const re = new RegExp(`\\b${count}\\s*bottle`, 'i');
  const matched = product.variants.nodes.find(
    (v) => re.test(v.title) && v.availableForSale
  );
  return matched?.id ?? null;
}

const starterId = variantIdFor(1);
const athleteId = variantIdFor(3);
const teamId = variantIdFor(6);

const heroImage = product?.featuredImage?.url
  ?? 'https://res.cloudinary.com/southland-organics/image/upload/JockShock/beckham4.jpg';
const heroImageAlt = product?.featuredImage?.altText ?? 'JockShock bottle';

const bgImage = 'https://res.cloudinary.com/southland-organics/image/upload/JockShock/beckham2_t9b1zk.jpg';
const problemImage = 'https://res.cloudinary.com/southland-organics/image/upload/JockShock/beckham1.jpg';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
</head>
<body>

  <CartDrawer client:idle />

  <!-- Launch Banner -->
  <div class="launch-banner">
    🚨 LAUNCH WEEK: First 500 Orders Get Free Team Sticker Pack 🚨
  </div>

  <!-- Header -->
  <header class="site-header">
    <div class="header-content">
      <div class="logo">
        <img src="/JockShock_Logo.png" alt="JockShock" class="header-logo">
      </div>
      <div class="header-actions">
        <JockShockBuyButton client:load variantId={starterId} label="GET JOCKSHOCK — $24.99" />
        <div class="cart-icon-wrap">
          <CartIcon client:load />
        </div>
      </div>
    </div>
  </header>

  <!-- Hero Section -->
  <section class="hero" style={`background-image: linear-gradient(135deg, rgba(13, 13, 13, 0.95) 0%, rgba(26, 26, 26, 0.75) 100%), url('${bgImage}');`}>
    <div class="hero-content">
      <div class="logo-with-tag">
        <img src="/JockShock_Logo_Tag.png" alt="JockShock - Shock the Stink. Own Your Game." class="hero-logo">
      </div>
      <h2 class="hero-headline">CLINICAL STRENGTH<br>GEAR PROTECTION</h2>
      <div class="trust-badges">
        <span class="badge-icon-item">🏆 Built by D1 Athletes</span>
        <span class="badge-icon-item">🧪 EPA-Registered Formula</span>
      </div>
      <JockShockBuyButton client:load variantId={starterId} label="GET JOCKSHOCK — $24.99" classList="cta-primary hero-cta" />
      <p class="shipping-note">Free shipping on 3+ bottles</p>
      <p class="urgency-text">⚡ Only 47 bottles left at launch price</p>
    </div>
    <div class="hero-image">
      {product?.featuredImage ? (
        <img src={heroImage} alt={heroImageAlt} class="hero-product-image" />
      ) : (
        <div class="product-placeholder">
          <div class="product-mockup">
            <div class="bottle-shape"></div>
            <p style="color: var(--athletic-safety-yellow); font-weight: 900; margin-top: 20px;">JOCKSHOCK</p>
            <p style="color: var(--clinical-silver); font-size: 14px;">32oz Spray</p>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Problem Agitation Section -->
  <section class="problem-section" style={`background-image: linear-gradient(rgba(255, 255, 255, 0.92), rgba(255, 255, 255, 0.92)), url('${problemImage}');`}>
    <div class="problem-grid">
      <div class="problem-card">
        <div class="problem-icon">🦨</div>
        <h3>GEAR STINK</h3>
        <p>Bacteria multiplies 2x every 20 minutes</p>
      </div>
      <div class="problem-card">
        <div class="problem-icon">💸</div>
        <h3>LOST INVESTMENT</h3>
        <p>$500+ gear ruined by odor</p>
      </div>
      <div class="problem-card">
        <div class="problem-icon">😰</div>
        <h3>CONFIDENCE KILLER</h3>
        <p>73% of athletes worry about gear smell</p>
      </div>
    </div>
    <p class="transition-text">One Spray Changes Everything</p>
  </section>

  <!-- How It Works Section -->
  <section class="how-it-works">
    <h2>3 STEPS TO FRESH GEAR</h2>
    <div class="steps">
      <div class="step">
        <div class="step-number">1</div>
        <h3>SPRAY</h3>
        <p>6-8 inches from gear</p>
      </div>
      <div class="step">
        <div class="step-number">2</div>
        <h3>SHOCK</h3>
        <p>Bacteria eliminated on contact</p>
      </div>
      <div class="step">
        <div class="step-number">3</div>
        <h3>PLAY</h3>
        <p>24-hour protection locked in</p>
      </div>
    </div>
    <JockShockBuyButton client:load variantId={athleteId} label="PROTECT YOUR GEAR NOW" classList="cta-secondary" />
    <div class="social-proof-bar">
      <p>⭐ Join 500+ Athletes Who've Shocked Their Stink</p>
    </div>
  </section>

  <!-- Pricing Section -->
  <section class="pricing">
    <div class="pricing-inner">
      <h2 style="text-align: center; margin-bottom: 60px;">CHOOSE YOUR PROTECTION</h2>
      <div class="pricing-cards">
      <div class="pricing-card">
        <h3>STARTER</h3>
        <p class="price">$24.99</p>
        <p class="description">1 Bottle</p>
        <JockShockBuyButton client:load variantId={starterId} />
      </div>
      <div class="pricing-card featured">
        <span class="badge">MOST POPULAR</span>
        <h3>ATHLETE PACK</h3>
        <p class="price"><s style="color: var(--clinical-silver);">$74.97</s> $59.99</p>
        <p class="description">3 Bottles</p>
        <p class="savings-big">SAVE $15</p>
        <p class="savings">Save 20% + FREE SHIPPING</p>
        <JockShockBuyButton client:load variantId={athleteId} />
      </div>
      <div class="pricing-card">
        <h3>TEAM PACK</h3>
        <p class="price"><s style="color: var(--clinical-silver);">$149.94</s> $99.99</p>
        <p class="description">6 Bottles</p>
        <p class="savings">Save 33% + FREE SHIPPING</p>
        <JockShockBuyButton client:load variantId={teamId} />
        <p class="team-quote-prompt">
          Outfitting a full program?
          <a href="/team-quote" class="team-quote-link">Get a team quote →</a>
        </p>
      </div>
    </div>
    </div>
  </section>

  <!-- Guarantee Section -->
  <section class="guarantee">
    <h2>30-DAY MONEY BACK GUARANTEE</h2>
    <p class="guarantee-text">Love it or your money back. No questions, no returns needed.</p>
    <div class="guarantee-badges">
      <div class="badge-item">
        <div class="badge-icon">✓</div>
        <p>Money Back Guarantee</p>
      </div>
      <div class="badge-item">
        <div class="badge-icon">🇺🇸</div>
        <p>Made in USA</p>
      </div>
      <div class="badge-item">
        <div class="badge-icon">✓</div>
        <p>EPA Registered</p>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="trust-footer-bar">
      <span>🔒 Secure Checkout</span>
      <span>🇺🇸 Made in USA</span>
      <span>✓ EPA Registered</span>
    </div>
    <p>&copy; 2025 JockShock. All rights reserved.</p>
    <p>Clinical-strength gear protection for serious athletes.</p>
  </footer>

<style>
  /* Launch Banner */
  .launch-banner {
    background: var(--athletic-safety-yellow);
    color: var(--tactical-black);
    text-align: center;
    padding: 12px;
    font-weight: 700;
    font-size: 14px;
  }

  /* Header */
  .site-header {
    background: var(--tactical-black);
    padding: 20px 5%;
    position: sticky;
    top: 0;
    z-index: 1000;
  }

  .header-content {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .cart-icon-wrap {
    color: var(--athletic-safety-yellow);
  }

  .logo {
    color: var(--athletic-safety-yellow);
  }

  .header-logo {
    height: 40px;
    width: auto;
    filter: drop-shadow(0 0 1px var(--athletic-safety-yellow));
  }

  /* Hero Section */
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    min-height: 90vh;
    background-position: center;
    background-size: cover;
    background-repeat: no-repeat;
    background-attachment: fixed;
    color: white;
    padding: 80px 5%;
    position: relative;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(ellipse at center, transparent 0%, rgba(13, 13, 13, 0.4) 100%);
    pointer-events: none;
  }

  .hero-content {
    max-width: 600px;
    position: relative;
    z-index: 1;
  }

  .logo-with-tag {
    margin-bottom: 32px;
  }

  .hero-image {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-logo {
    max-width: 100%;
    width: 500px;
    height: auto;
    filter: invert(1); /* Makes black logo white */
  }

  .hero-product-image {
    max-width: 100%;
    width: 500px;
    height: auto;
    filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.5));
  }

  .hero-headline {
    margin-bottom: 24px;
    color: white;
  }

  .trust-badges {
    display: flex;
    gap: 24px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }

  .badge-icon-item {
    font-size: 16px;
    color: var(--athletic-safety-yellow);
    font-weight: 700;
    background: rgba(255, 229, 0, 0.15);
    padding: 8px 16px;
    border-radius: 4px;
    border: 1px solid var(--athletic-safety-yellow);
  }

  .hero-cta {
    font-size: 18px;
    padding: 20px 40px;
    box-shadow: 0 4px 12px rgba(255, 229, 0, 0.3);
  }

  .hero-cta:hover {
    box-shadow: 0 6px 20px rgba(255, 229, 0, 0.5);
  }

  .shipping-note {
    margin-top: 12px;
    font-size: 14px;
    color: var(--clinical-silver);
  }

  .urgency-text {
    margin-top: 8px;
    font-size: 14px;
    color: var(--caution-orange);
    font-weight: 700;
  }

  .product-placeholder {
    background: rgba(255, 229, 0, 0.1);
    border: 2px dashed var(--athletic-safety-yellow);
    border-radius: 8px;
    padding: 60px;
    text-align: center;
  }

  .product-mockup {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .bottle-shape {
    width: 120px;
    height: 280px;
    background: linear-gradient(180deg, var(--athletic-safety-yellow) 0%, #ffd000 100%);
    border-radius: 20px 20px 40px 40px;
    position: relative;
    box-shadow: 0 20px 40px rgba(0,0,0,0.3), inset -4px 0 12px rgba(255,255,255,0.4);
    transform: rotate(15deg);
  }

  .bottle-shape::before {
    content: '';
    position: absolute;
    top: -20px;
    left: 50%;
    transform: translateX(-50%);
    width: 40px;
    height: 30px;
    background: var(--tactical-black);
    border-radius: 4px 4px 0 0;
  }

  .bottle-shape::after {
    content: '';
    position: absolute;
    top: 30%;
    right: -4px;
    width: 3px;
    height: 40%;
    background: rgba(255, 255, 255, 0.6);
    border-radius: 2px;
  }

  /* Problem Section */
  .problem-section {
    background-color: white;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    text-align: center;
  }

  .problem-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 40px;
    margin-bottom: 60px;
  }

  .problem-card {
    padding: 40px;
    background: var(--tactical-black);
    color: white;
    border-left: 4px solid var(--athletic-safety-yellow);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .problem-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 20px rgba(255, 229, 0, 0.2);
  }

  .problem-icon {
    font-size: 48px;
    margin-bottom: 16px;
  }

  .problem-card h3 {
    color: var(--athletic-safety-yellow);
    margin-bottom: 16px;
  }

  .transition-text {
    font-size: 32px;
    font-weight: 700;
    color: var(--tactical-black);
    margin-top: 40px;
  }

  /* How It Works */
  .how-it-works {
    background: var(--performance-white);
    text-align: center;
  }

  .how-it-works h2 {
    margin-bottom: 60px;
  }

  .steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 60px;
    margin-bottom: 60px;
  }

  .step {
    text-align: center;
  }

  .step-number {
    width: 80px;
    height: 80px;
    background: var(--athletic-safety-yellow);
    color: var(--tactical-black);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 48px;
    font-weight: 900;
    margin: 0 auto 24px;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.05); }
  }

  .step h3 {
    margin-bottom: 12px;
  }

  .social-proof-bar {
    margin-top: 40px;
    text-align: center;
    padding: 20px;
    background: rgba(255, 229, 0, 0.1);
    border-radius: 8px;
  }

  .social-proof-bar p {
    font-size: 18px;
    font-weight: 700;
    color: var(--tactical-black);
  }

  /* Pricing Section */
  .pricing {
    background: var(--tactical-black);
    color: white;
    max-width: 100%;
    padding-left: 0;
    padding-right: 0;
    padding-top: 0;
  }

  .pricing-inner {
    position: relative;
    top: -25px;
    background: var(--tactical-black);
    padding: 60px 5% 80px;
    max-width: 1400px;
    margin: 0 auto;
    border-radius: 8px;
    box-shadow: 0 -10px 30px rgba(0, 0, 0, 0.3);
  }

  .pricing h2 {
    color: white;
  }

  .pricing-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 40px;
  }

  .pricing-card {
    background: #1a1a1a;
    padding: 40px;
    text-align: center;
    position: relative;
    border: 2px solid transparent;
    transition: transform 0.3s;
  }

  .pricing-card:hover {
    transform: translateY(-8px);
  }

  .pricing-card.featured {
    border: 3px solid var(--athletic-safety-yellow);
    transform: scale(1.05);
    background: #2a2a2a;
    box-shadow: 0 0 30px rgba(255, 229, 0, 0.3);
  }

  .badge {
    position: absolute;
    top: -15px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--athletic-safety-yellow);
    color: var(--tactical-black);
    padding: 6px 20px;
    font-size: 14px;
    font-weight: 900;
    letter-spacing: 0.05em;
    box-shadow: 0 4px 8px rgba(0,0,0,0.3);
  }

  .pricing-card h3 {
    color: var(--athletic-safety-yellow);
    margin-bottom: 24px;
  }

  .price {
    font-size: 48px;
    font-weight: 900;
    margin-bottom: 16px;
    color: white;
  }

  .description {
    margin-bottom: 16px;
    color: var(--clinical-silver);
  }

  .savings-big {
    color: var(--caution-orange);
    font-weight: 900;
    font-size: 20px;
    margin-bottom: 8px;
  }

  .savings {
    color: var(--athletic-safety-yellow);
    font-weight: 700;
    margin-bottom: 24px;
  }

  .team-quote-prompt {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid #2a2a2a;
    font-size: 13px;
    color: var(--clinical-silver);
  }

  .team-quote-link {
    color: var(--athletic-safety-yellow);
    font-weight: 700;
    text-decoration: none;
    display: inline-block;
    margin-left: 4px;
  }

  .team-quote-link:hover {
    text-decoration: underline;
  }

  /* Guarantee Section */
  .guarantee {
    background: white;
    text-align: center;
  }

  .guarantee h2 {
    margin-bottom: 24px;
  }

  .guarantee-text {
    font-size: 18px;
    margin-bottom: 60px;
    color: var(--tactical-black);
  }

  .guarantee-badges {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 40px;
  }

  .badge-item {
    text-align: center;
  }

  .badge-icon {
    width: 80px;
    height: 80px;
    background: var(--athletic-safety-yellow);
    color: var(--tactical-black);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 40px;
    margin: 0 auto 16px;
  }

  /* Footer */
  .site-footer {
    background: var(--tactical-black);
    color: var(--clinical-silver);
    text-align: center;
    padding: 40px 5%;
  }

  .trust-footer-bar {
    display: flex;
    justify-content: center;
    gap: 40px;
    margin-bottom: 24px;
    padding: 16px;
    border-top: 1px solid var(--clinical-silver);
    border-bottom: 1px solid var(--clinical-silver);
  }

  .trust-footer-bar span {
    color: var(--athletic-safety-yellow);
    font-weight: 600;
    font-size: 14px;
  }

  .site-footer p {
    margin: 8px 0;
  }

  /* Mobile Responsive */
  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
      padding: 60px 5%;
      background-attachment: scroll;
    }

    .hero-image {
      order: -1;
    }

    .product-placeholder {
      padding: 40px;
    }

    .header-content {
      flex-direction: column;
      gap: 16px;
    }

    .pricing-cards,
    .steps,
    .problem-grid,
    .guarantee-badges {
      grid-template-columns: 1fr;
    }

    .pricing-card.featured {
      transform: scale(1);
    }

    .trust-badges {
      flex-direction: column;
      gap: 12px;
    }

    .hero-logo {
      width: 300px;
    }

    .hero-product-image {
      width: 300px;
    }

    .header-logo {
      height: 30px;
    }

    .trust-footer-bar {
      flex-direction: column;
      gap: 12px;
    }

    .badge-icon-item {
      font-size: 14px;
      padding: 6px 12px;
    }

    .urgency-text {
      font-size: 12px;
    }

    .social-proof-bar p {
      font-size: 16px;
    }
  }
</style>
</body>
</html>
