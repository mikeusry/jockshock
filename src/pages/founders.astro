---
/**
 * /founders — the four UGA D1 athletes behind JockShock.
 *
 * The credibility layer the rest of the site leans on. The "Built by D1
 * Athletes" badge on the homepage cashes in here: four real people, four
 * verified D1 careers, four roles on this thing.
 *
 * Voice: Aaron-led with a slightly slower cadence — this is the "who" page,
 * not the "buy" page. Same dark register as /parents and the homepage,
 * uses the established js-{name} CSS scoping pattern with --jockshock-*
 * custom properties.
 *
 * Image sourcing:
 *   - Mike + Karin: Cloudinary (Southland Organics asset library, same
 *     headshots used on southlandorganics.com/team/*)
 *   - Fred + Anna: D1 Training franchise team page (Mike-supplied URLs)
 *
 * If/when we shoot proper JockShock-branded portraits, swap the URLs.
 *
 * Page order: Mike → Karin → Fred → Anna. Founder-by-founder narrative arc:
 *   Mike opens (CEO) → Karin (gym channel pitch + gymnastics credential) →
 *   Fred (gym channel lead) → Anna (strength credential close).
 */
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Founders — Built by D1 Athletes | JockShock";
const description =
  "JockShock was built by four UGA D1 athletes who lived in this gear. Mike Usry, Karin Lichey Usry, Fred Munzenmaier, and Anna Watson on what they're doing and why.";

interface Founder {
  name: string;
  role: string;
  credential: string;
  bio: string;
  photo: string;
  alt: string;
}

const founders: Founder[] = [
  {
    name: "Mike Usry",
    role: "Founder · CEO, Southland Organics",
    credential: "UGA Football",
    bio: "Mike played football at the University of Georgia and built Southland Organics from the kitchen table to a multi-brand company. JockShock is the brand he wishes he'd had during two-a-days. He runs day-to-day for the brand, owns the chemistry and supply side, and spent two decades figuring out what athletes actually need vs. what brands try to sell them.",
    photo:
      "https://res.cloudinary.com/southland-organics/image/upload/w_900,h_900,c_fill,g_face,f_auto,q_auto/Southland%20Website/team/MIKE_Usry",
    alt: "Mike Usry, founder of JockShock and CEO of Southland Organics",
  },
  {
    name: "Karin Lichey Usry",
    role: "Co-Founder · Strategy",
    credential: "UGA Gymnastics — 11× All-American · Honda Award · Perfect 40",
    bio: "Karin's gymnastics career at Georgia is one of the most decorated in NCAA history — 11-time All-American, Honda Award winner, the rare athlete who scored a perfect 40 in competition. She brought the gym channel idea to JockShock and helped shape what the brand stands for. When we say \"built by D1 athletes,\" Karin is the one who lived at the highest level of the sport.",
    photo:
      "https://res.cloudinary.com/southland-organics/image/upload/w_900,h_900,c_fill,g_face,f_auto,q_auto/Southland%20Website/team/KARIN_Usry",
    alt: "Karin Lichey Usry, co-founder and 11-time All-American UGA gymnast",
  },
  {
    name: "Fred Munzenmaier",
    role: "Founder · Gym Channel",
    credential: "UGA Football · D1 Training Franchise Owner",
    bio: "Fred played running back at the University of Georgia and now owns a D1 Training franchise. He runs the gym channel for JockShock — every gym, every program, every coach lead routes to him first. Athlete-to-athlete, gym-owner-to-gym-owner. If you're a coach or facility operator, Fred is your point of contact.",
    photo:
      "https://dbndiuxsumrq4.cloudfront.net/unsafe/f:webp/g:sm/w:1080/plain/https://d1-website.s3.us-east-1.amazonaws.com/media/teams/ca6bb996-fcb7-46fc-b29b-e591a54d7d25.png",
    alt: "Fred Munzenmaier, founder and gym channel lead at JockShock",
  },
  {
    name: "Anna Watson",
    role: "Founder · Strength & Programs",
    credential: "UGA Cheerleading · Strength Coach, D1 Training",
    bio: "Anna's been called \"the world's strongest cheerleader\" — a UGA cheerleader who became one of the most respected strength athletes online and now coaches at D1 Training. She brings the in-the-trenches strength-coach perspective to JockShock and shapes how the program lands inside actual training facilities. If you've seen the videos, you know.",
    photo:
      "https://dbndiuxsumrq4.cloudfront.net/unsafe/f:webp/g:sm/w:1080/plain/https://d1-website.s3.us-east-1.amazonaws.com/media/teams/30b6acf9-0d0b-4eb4-8c9c-5d6e6045c2f4.png",
    alt: "Anna Watson, founder and strength-coach voice for JockShock",
  },
];
---

<BaseLayout title={title} description={description}>
  <div class="js-founders">
    <!-- HERO -->
    <section class="hero">
      <div class="hero-bg" aria-hidden="true"></div>
      <div class="hero-overlay" aria-hidden="true"></div>
      <div class="hero-inner">
        <p class="eyebrow">Built by D1 Athletes</p>
        <h1 class="hero-headline">
          Four athletes.<br />One bottle.
        </h1>
        <p class="hero-sub">
          JockShock wasn't built by a chemist looking for a market. It was built
          by athletes who lived in this gear and got tired of the only options
          being a fragrance bomb or nothing at all.
        </p>
        <p class="hero-promise">
          Here's who's behind it, what we did, and why we're doing this now.
        </p>
      </div>
    </section>

    <!-- FOUNDER GRID -->
    <section class="people">
      <div class="people-inner">
        {
          founders.map((f, i) => (
            <article class={`founder ${i % 2 === 1 ? "founder--reverse" : ""}`}>
              <div class="founder-photo-wrap">
                <img
                  src={f.photo}
                  alt={f.alt}
                  class="founder-photo"
                  width="900"
                  height="900"
                  loading={i < 2 ? "eager" : "lazy"}
                />
              </div>
              <div class="founder-copy">
                <p class="founder-role">{f.role}</p>
                <h2 class="founder-name">{f.name}</h2>
                <p class="founder-credential">{f.credential}</p>
                <p class="founder-bio">{f.bio}</p>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="final-cta">
      <div class="final-cta-inner">
        <h2>That's the team.</h2>
        <p>Now grab a bottle.</p>
        <div class="cta-row">
          <a href="/products/jockshock/" class="cta-primary">Get JockShock</a>
          <a href="/teams/" class="cta-secondary">For coaches & teams</a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .js-founders {
    --jockshock-black: #0a0a0a;
    --jockshock-yellow: #ffe500;
    --jockshock-yellow-warm: #fbbf24;
    --jockshock-text: #f3f4f6;
    --jockshock-muted: #9ca3af;
    background: var(--jockshock-black);
    color: var(--jockshock-text);
    font-family:
      -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
  }

  .js-founders h1,
  .js-founders h2,
  .js-founders h3 {
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .eyebrow {
    color: var(--jockshock-yellow);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 700;
    font-size: 0.8125rem;
    margin: 0 0 16px;
  }

  /* === HERO ===
     Cinematic dark texture background with a yellow side-glow overlay. Same
     vibe as the homepage hero (carbon + heat) but no athlete-specific
     imagery — that would compete with the four real founder photos below.
     The background image is a dark abstract texture (Cloudinary asset
     dark-abstract-texture-pattern-background-with-spot). */
  .hero {
    position: relative;
    background: #0a0a0a;
    padding: 120px 5% 100px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    overflow: hidden;
    isolation: isolate;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background-image: url("https://res.cloudinary.com/southland-organics/image/upload/c_fill,w_2400,h_1200,g_auto,q_auto,f_auto/JockShock/dark-abstract-texture-pattern-background-with-spot_rpsqte");
    background-size: cover;
    background-position: center;
    opacity: 0.55;
    z-index: -2;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        ellipse at 80% 30%,
        rgba(255, 229, 0, 0.10) 0%,
        transparent 55%
      ),
      linear-gradient(
        135deg,
        rgba(10, 10, 10, 0.55) 0%,
        rgba(10, 10, 10, 0.85) 65%,
        rgba(10, 10, 10, 0.95) 100%
      );
    z-index: -1;
  }
  .hero-inner {
    position: relative;
    max-width: 920px;
    margin: 0 auto;
    text-align: left;
  }
  .hero-headline {
    font-size: clamp(2.4rem, 5vw, 4rem);
    color: #fff;
    line-height: 1.05;
    margin: 0 0 24px;
  }
  .hero-sub {
    font-size: 1.125rem;
    color: #d1d5db;
    line-height: 1.6;
    max-width: 64ch;
    margin: 0 0 16px;
  }
  .hero-promise {
    font-size: 1.0625rem;
    color: var(--jockshock-text);
    line-height: 1.6;
    margin: 0;
    padding: 16px 20px;
    background: rgba(255, 229, 0, 0.06);
    border-left: 3px solid var(--jockshock-yellow);
    max-width: 56ch;
  }

  /* === PEOPLE GRID ===
     Alternating photo/copy, each founder is a single horizontal block on
     desktop and stacks photo-then-copy on mobile. Carbon-black bg with
     yellow accent rule above each card to match the established register. */
  .people {
    background: var(--jockshock-black);
    padding: 80px 5%;
  }
  .people-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 80px;
  }

  .founder {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 56px;
    align-items: center;
    padding-top: 32px;
    border-top: 1px solid rgba(255, 229, 0, 0.18);
  }
  .founder:first-child {
    padding-top: 0;
    border-top: none;
  }

  .founder--reverse {
    grid-template-columns: 1.4fr 1fr;
  }
  .founder--reverse .founder-photo-wrap {
    order: 2;
  }
  .founder--reverse .founder-copy {
    order: 1;
  }

  .founder-photo-wrap {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 6px;
    background: #1a1a1a;
    border: 1px solid rgba(255, 229, 0, 0.18);
  }
  .founder-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .founder-role {
    color: var(--jockshock-yellow);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin: 0 0 8px;
  }
  .founder-name {
    font-size: clamp(1.875rem, 3vw, 2.5rem);
    color: #fff;
    line-height: 1.1;
    margin: 0 0 6px;
  }
  .founder-credential {
    font-size: 0.95rem;
    color: var(--jockshock-yellow-warm);
    font-weight: 600;
    margin: 0 0 20px;
  }
  .founder-bio {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: #d1d5db;
    max-width: 60ch;
    margin: 0;
  }

  /* === FINAL CTA ===
     Mirrors /parents .final-cta — same yellow background, same emphatic
     tagline, same primary/secondary CTA pair. */
  .final-cta {
    background: var(--jockshock-yellow);
    color: var(--jockshock-black);
    padding: 80px 5%;
    text-align: center;
  }
  .final-cta-inner {
    max-width: 720px;
    margin: 0 auto;
  }
  .final-cta h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--jockshock-black);
    margin: 0 0 8px;
    line-height: 1.1;
  }
  .final-cta p {
    font-size: 1.125rem;
    color: rgba(10, 10, 10, 0.85);
    margin: 0 0 32px;
  }

  .cta-row {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .cta-primary,
  .cta-secondary {
    display: inline-block;
    padding: 14px 28px;
    border-radius: 6px;
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    transition:
      transform 0.15s,
      box-shadow 0.15s,
      background 0.15s;
  }
  .cta-primary {
    background: var(--jockshock-black);
    color: var(--jockshock-yellow);
  }
  .cta-primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 24px -8px rgba(10, 10, 10, 0.4);
  }
  .cta-secondary {
    background: transparent;
    color: var(--jockshock-black);
    border: 1px solid rgba(10, 10, 10, 0.4);
  }
  .cta-secondary:hover {
    background: rgba(10, 10, 10, 0.08);
  }

  @media (max-width: 760px) {
    .hero {
      padding: 64px 5% 56px;
    }
    .founder,
    .founder--reverse {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .founder--reverse .founder-photo-wrap {
      order: 0;
    }
    .founder--reverse .founder-copy {
      order: 1;
    }
    .founder-photo-wrap {
      max-width: 480px;
      margin: 0 auto;
    }
    .people-inner {
      gap: 56px;
    }
    .people {
      padding: 56px 5%;
    }
  }
</style>

<script>
  // Pixel event for the founders page view. Persona is intentionally NOT
  // stamped here — /founders is brand/credibility, not persona-targeted.
  // Whoever lands here keeps whatever persona they had (or 'general' if
  // first-touch).
  if (typeof window !== "undefined" && (window as any).pdPixel) {
    (window as any).pdPixel.track("founders_view", {
      sub_brand: "jockshock",
    });
  }
</script>
