    width: 100%;
    margin-top: 8px;
  }
  .form-note {
    color: var(--steel);
    font-size: 12px;
    text-align: center;
    margin: 16px 0 0;
    letter-spacing: 0.04em;
  }
  .form-error {
    color: #fca5a5;
    background: rgba(239, 68, 68, 0.1);
    border-left: 3px solid #ef4444;
