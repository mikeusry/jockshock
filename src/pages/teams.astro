---
/**
 * /teams — Carmen's B2B intake page.
 *
 * Per persona work + brand-brief.md: Carmen is the team / facility / program
 * buyer. The 6-pack consumer SKU is wrong-shape for her — she wants gallons
 * or 5-gal pails (v2). This page is a quote-form intake, not a consumer
 * add-to-cart.
 *
 * Aaron-voice rule: this is a Carmen surface, so voice translates to
 * professional / operations-flavored. No locker-room slang. No parent-
 * emotional framing. Treat the visitor like a peer program-runner.
 *
 * Form submit: POSTs to /api/teams-intake (TODO — placeholder for now;
 * a follow-up wires Klaviyo + HubSpot per persona doc).
 */
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "JockShock for Teams — Program Quote";
const description =
  "JockShock for coaches, athletic trainers, club directors, and gym owners. Volume pricing, sanitation protocol PDFs, and per-athlete cost calculators for your program.";
---

<BaseLayout title={title} description={description}>
  <div class="js-teams">
    <!-- HERO -->
    <section class="hero">
      <div class="hero-inner">
        <p class="eyebrow">For coaches, ATCs, club directors, and facility owners</p>
        <h1 class="hero-headline">
          Program-wide gear deodorizer.<br />Built so your roster doesn't bring an outbreak home.
        </h1>
        <p class="hero-sub">
          JockShock is the equipment deodorizer programs actually use — not a
          household cleaner repackaged for the locker room. EPA-registered HOCl
          chemistry, gear-safe materials, and a written sanitation protocol
          you can hand to your assistants and athletic trainers.
        </p>
        <a href="#quote" class="cta">Request a program quote</a>
      </div>
    </section>

    <!-- WHAT YOU GET -->
    <section class="what">
      <div class="what-inner">
        <p class="section-eyebrow">What you get</p>
        <h2 class="section-headline">Built around what programs actually need.</h2>
        <div class="what-grid">
          <div class="what-card">
            <h3>Volume pricing</h3>
            <p>
              Per-athlete pricing scales with your roster — 12 athletes or 200,
              hockey rink or wrestling room. Bulk shipping to one address or
              split-shipped across multiple sites.
            </p>
          </div>
          <div class="what-card">
            <h3>Written protocol</h3>
            <p>
              A sanitation protocol PDF you can drop into your binder, post in
              the locker room, and hand to assistants. Mat-room specific.
              Locker-room specific. Pre-season checklist included.
            </p>
          </div>
          <div class="what-card">
            <h3>Documentation on file</h3>
            <p>
              EPA registration, SDS, application instructions — all available
              for your AD, your facilities team, or your compliance officer.
              No back-and-forth.
            </p>
          </div>
          <div class="what-card">
            <h3>Replenishment cadence</h3>
            <p>
              Quarterly or seasonal restock based on your program's roster size.
              Auto-ship if you want it; one-and-done if you don't. No surprises.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- WHO -->
    <section class="who">
      <div class="who-inner">
        <p class="section-eyebrow">Who we work with</p>
        <h2 class="section-headline">If your program shares gear or a locker room, this is for you.</h2>
        <ul class="who-list">
          <li>High school athletic programs (football, hockey, lacrosse, wrestling, soccer)</li>
          <li>Club and travel-team programs</li>
          <li>College athletic departments and club teams</li>
          <li>MMA, jiu-jitsu, and combat-sports gyms</li>
          <li>Boxing and wrestling rooms</li>
          <li>Cheerleading and tumbling facilities</li>
          <li>Athletic training facilities and PT clinics</li>
          <li>Recreation centers, YMCAs, and municipal sports programs</li>
        </ul>
      </div>
    </section>

    <!-- QUOTE FORM -->
    <section class="quote" id="quote">
      <div class="quote-inner">
        <p class="section-eyebrow">Request a quote</p>
        <h2 class="section-headline">Tell us about your program. We'll get back within one business day.</h2>

        <div class="quote-success" data-success hidden>
          <h3>Got it. We'll be in touch.</h3>
          <p>
            Mike or someone from the team will email you within one business
            day with a quote tailored to your roster size and sport. If you
            need to chat sooner, reach out directly: <a href="mailto:mike@southlandorganics.com">mike@southlandorganics.com</a>.
          </p>
        </div>

        <form class="quote-form" method="POST" action="/api/teams-intake" data-quote-form>
          <div class="form-row">
            <label>
              <span>Your name</span>
              <input type="text" name="name" required autocomplete="name" />
            </label>
            <label>
              <span>Role</span>
              <select name="role" required>
                <option value="">Select…</option>
                <option>Head coach</option>
                <option>Assistant coach</option>
                <option>Athletic trainer (ATC)</option>
                <option>Club / program director</option>
                <option>Athletic director</option>
                <option>Gym / facility owner</option>
                <option>Equipment manager</option>
                <option>Other</option>
              </select>
            </label>
          </div>

          <div class="form-row">
            <label>
              <span>Program / organization</span>
              <input type="text" name="organization" required autocomplete="organization" />
            </label>
            <label>
              <span>Email</span>
              <input type="email" name="email" required autocomplete="email" />
            </label>
          </div>

          <div class="form-row">
            <label>
              <span>Phone (optional)</span>
              <input type="tel" name="phone" autocomplete="tel" />
            </label>
            <label>
              <span>Sport</span>
              <select name="sport" required>
                <option value="">Select…</option>
                <option>Hockey</option>
                <option>Lacrosse</option>
                <option>Wrestling</option>
                <option>Football</option>
                <option>MMA / BJJ</option>
                <option>Soccer</option>
                <option>Multi-sport program</option>
                <option>Other</option>
              </select>
            </label>
          </div>

          <div class="form-row">
            <label>
              <span>Roster size (athletes)</span>
              <select name="roster_size" required>
                <option value="">Select…</option>
                <option>Under 25</option>
                <option>25–50</option>
                <option>50–100</option>
                <option>100–200</option>
                <option>200+</option>
              </select>
            </label>
            <label>
              <span>Decision timeline</span>
              <select name="timeline" required>
                <option value="">Select…</option>
                <option>This week (urgent)</option>
                <option>This month</option>
                <option>This quarter</option>
                <option>Next budget cycle</option>
                <option>Just exploring</option>
              </select>
            </label>
          </div>

          <label class="form-fullwidth">
            <span>What you're trying to solve (optional)</span>
            <textarea
              name="notes"
              rows="4"
              placeholder="Outbreak in the program? Pre-season prep? Just upgrading from a household cleaner? Whatever the context — short answer is fine."
            ></textarea>
          </label>

          <input type="hidden" name="persona" value="carmen" />
          <input type="hidden" name="source" value="jockshock-teams-page" />

          <button type="submit" class="cta cta-submit">Send the request</button>
          <p class="form-note">
            We'll reply within one business day. No marketing spam, no auto-enrollment.
          </p>
        </form>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  // Stamp persona=carmen as soon as someone lands on /teams (positive signal
  // per the persona-gap memory + brand-brief — Carmen requires positive
  // signal, never defaults). Done client-side because the cookie sets
  // happen in the existing persona module which is browser-only.
  import { setPersona } from "../utils/persona-stamp";
  setPersona("carmen");

  // Pixel event for the lander itself
  if (typeof window !== "undefined" && (window as any).pdPixel) {
    (window as any).pdPixel.track("teams_lander_view", {
      sub_brand: "jockshock",
      persona: "carmen",
    });
  }

  // Form submit: POST JSON to /api/teams-intake, render thank-you on success.
  const form = document.querySelector<HTMLFormElement>("[data-quote-form]");
  const successPanel = document.querySelector<HTMLElement>("[data-success]");
  const submitBtn = form?.querySelector<HTMLButtonElement>(".cta-submit");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form || !submitBtn) return;

    submitBtn.disabled = true;
    const originalLabel = submitBtn.textContent;
    submitBtn.textContent = "Sending…";

    const fd = new FormData(form);
    const payload = Object.fromEntries(fd.entries());

    // Pixel — fire BEFORE the network call so the click is captured even if
    // the API is slow or fails.
    if ((window as any).pdPixel) {
      (window as any).pdPixel.track("teams_quote_submitted", {
        sub_brand: "jockshock",
        persona: "carmen",
        sport: payload.sport,
        roster_size: payload.roster_size,
        timeline: payload.timeline,
        role: payload.role,
      });
    }

    try {
      const r = await fetch("/api/teams-intake", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });
      if (!r.ok) throw new Error(`Server returned ${r.status}`);
      // Swap form for thank-you panel
      form.hidden = true;
      if (successPanel) {
        successPanel.hidden = false;
        successPanel.scrollIntoView({ behavior: "smooth", block: "center" });
      }
    } catch (err) {
      console.error("[teams-intake] submit failed", err);
      submitBtn.disabled = false;
      submitBtn.textContent = originalLabel;
      // Inline error so the user knows to try again or email directly.
      let errorEl = form.querySelector<HTMLElement>(".form-error");
      if (!errorEl) {
        errorEl = document.createElement("p");
        errorEl.className = "form-error";
        submitBtn.insertAdjacentElement("afterend", errorEl);
      }
      errorEl.textContent =
        "Something went wrong sending that. Email mike@southlandorganics.com directly and we'll handle it.";
    }
  });
</script>

<style>
  .js-teams {
    --jockshock-black: #0a0a0a;
    --jockshock-yellow: #facc15;
    --jockshock-text: #f3f4f6;
    --jockshock-muted: #9ca3af;
    background: var(--jockshock-black);
    color: var(--jockshock-text);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
  }
  .js-teams h1, .js-teams h2, .js-teams h3 {
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .eyebrow, .section-eyebrow {
    color: var(--jockshock-yellow);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 700;
    font-size: 0.8125rem;
    margin-bottom: 16px;
  }

  /* === HERO === */
  .hero {
    padding: 100px 5% 80px;
    background: linear-gradient(135deg, #1a1a1a 0%, #0a0a0a 100%);
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .hero-inner { max-width: 900px; margin: 0 auto; }
  .hero-headline {
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    color: #fff;
    line-height: 1.1;
    margin: 0 0 24px;
  }
  .hero-sub {
    font-size: 1.125rem;
    color: #d1d5db;
    line-height: 1.6;
    margin-bottom: 32px;
    max-width: 720px;
  }
  .cta {
    display: inline-block;
    background: var(--jockshock-yellow);
    color: var(--jockshock-black);
    padding: 18px 36px;
    text-decoration: none;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.9375rem;
    border: none;
    cursor: pointer;
    border-radius: 4px;
    transition: transform 0.1s ease, box-shadow 0.15s ease;
    font-family: inherit;
  }
  .cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(250, 204, 21, 0.35);
  }

  /* === SECTION HEADERS === */
  .section-headline {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    color: #fff;
    margin: 0 0 32px;
    line-height: 1.2;
  }

  /* === WHAT YOU GET === */
  .what { padding: 100px 5%; }
  .what-inner { max-width: 1200px; margin: 0 auto; }
  .what-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }
  .what-card {
    background: #141414;
    padding: 32px;
    border-left: 3px solid var(--jockshock-yellow);
  }
  .what-card h3 {
    color: var(--jockshock-yellow);
    font-size: 1.25rem;
    margin: 0 0 12px;
  }
  .what-card p { color: var(--jockshock-text); line-height: 1.6; margin: 0; }

  /* === WHO === */
  .who { padding: 100px 5%; background: #050505; }
  .who-inner { max-width: 900px; margin: 0 auto; }
  .who-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 12px 32px;
  }
  .who-list li {
    color: var(--jockshock-text);
    padding-left: 24px;
    position: relative;
    line-height: 1.5;
  }
  .who-list li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--jockshock-yellow);
    font-weight: 800;
  }

  /* === QUOTE FORM === */
  .quote { padding: 100px 5%; background: var(--jockshock-black); border-top: 1px solid rgba(255,255,255,0.08); }
  .quote-inner { max-width: 800px; margin: 0 auto; }
  .quote-form {
    background: #141414;
    padding: 40px;
    border-radius: 4px;
    margin-top: 16px;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
  }
  .form-fullwidth {
    display: block;
    margin-bottom: 24px;
  }
  .quote-form label {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .quote-form span {
    color: var(--jockshock-muted);
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .quote-form input,
  .quote-form select,
  .quote-form textarea {
    background: #0a0a0a;
    border: 1px solid rgba(255,255,255,0.1);
    color: #fff;
    padding: 14px 16px;
    border-radius: 4px;
    font-family: inherit;
    font-size: 1rem;
    transition: border-color 0.15s ease;
  }
  .quote-form input:focus,
  .quote-form select:focus,
  .quote-form textarea:focus {
    outline: none;
    border-color: var(--jockshock-yellow);
  }
  .quote-form textarea {
    resize: vertical;
    min-height: 100px;
  }
  .cta-submit {
    width: 100%;
    margin-top: 8px;
  }
  .form-note {
    color: var(--jockshock-muted);
    font-size: 0.8125rem;
    text-align: center;
    margin: 16px 0 0;
  }
  .form-error {
    color: #fca5a5;
    background: rgba(239, 68, 68, 0.1);
    border-left: 3px solid #ef4444;
    padding: 12px 16px;
    margin: 16px 0 0;
    font-size: 0.875rem;
    line-height: 1.5;
  }
  .quote-success {
    background: #141414;
    padding: 40px;
    border-left: 3px solid var(--jockshock-yellow);
    border-radius: 4px;
    margin-top: 16px;
  }
  .quote-success h3 {
    color: var(--jockshock-yellow);
    font-size: 1.5rem;
    margin: 0 0 16px;
  }
  .quote-success p {
    color: var(--jockshock-text);
    line-height: 1.7;
    font-size: 1rem;
    margin: 0;
  }
  .quote-success a {
    color: var(--jockshock-yellow);
    text-decoration: none;
    font-weight: 700;
  }
  .quote-success a:hover { text-decoration: underline; }

  @media (max-width: 768px) {
    .hero, .what, .who, .quote { padding: 64px 5%; }
    .form-row {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .quote-form { padding: 24px; }
  }
</style>
