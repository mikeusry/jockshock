    -webkit-text-stroke: 1px rgba(0,0,0,0.2);
  }

  /* SUBSCRIPTION ===================================================== */
  .subscription-section {
    background-color: var(--steel-50);
    border-top: 4px solid var(--electric-yellow);
  }
  .subscription-steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 24px;
  }
  .subscription-steps li {
    background: #fff;
    padding: 40px 32px;
    text-align: center;
    box-shadow: 0 2px 0 rgba(0,0,0,0.04), 0 8px 24px rgba(0,0,0,0.04);
  }
  .subscription-steps :global(.step-badge) {
    margin: 0 auto 20px;
  }
  .subscription-steps h3 {
    color: var(--ink);
    margin: 0 0 8px;
  }
  .subscription-steps p {
    color: var(--graphite);
    font-size: 15px;
    line-height: 1.5;
    margin: 0;
  }

  /* FRED ============================================================ */
  .fred-section {
    background-color: var(--carbon-black);
    background-image:
      linear-gradient(180deg, rgba(10,10,10,0.92) 0%, rgba(10,10,10,0.78) 60%, rgba(10,10,10,0.96) 100%),
      url("https://res.cloudinary.com/southland-organics/image/upload/c_fill,w_1800,h_900,g_auto,q_auto,f_jpg/v1778154580/JockShock/dark-abstract-texture-pattern-background-with-spot_rpsqte.jpg");
    background-size: cover;
    background-position: center;
    padding: 120px 5%;
  }
  .fred-inner {
    text-align: center;
  }
  .fred-headline {
    color: #fff;
    font-size: clamp(28px, 4vw, 44px);
    line-height: 1.15;
    margin-bottom: 48px;
  }
  .fred-card {
    background: #141414;
    border-left: 4px solid var(--electric-yellow);
    padding: 56px 48px;
    max-width: 720px;
    margin: 0 auto;
    text-align: left;
  }
  .fred-name {
    font-family: 'Bebas Neue', sans-serif;
    color: #fff;
    font-size: 40px;
    letter-spacing: 0.04em;
    line-height: 1;
    margin-bottom: 12px;
  }
  .fred-creds {
    color: var(--electric-yellow);
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .fred-body {
    color: #d1d5db;
    font-size: 16px;
    line-height: 1.7;
    margin: 24px 0 32px;
  }

  /* WHO LIST ========================================================= */
  .who-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 12px 32px;
    max-width: 1100px;
  }
  .who-list li {
    color: var(--ink);
    padding-left: 24px;
    position: relative;
    line-height: 1.6;
    font-size: 15px;
  }
  .who-list li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: #b08e00;
    font-weight: 800;
  }

  /* QUOTE FORM ====================================================== */
  .quote-section {
    padding: 120px 5%;
  }
  .quote-inner { max-width: 800px; margin: 0 auto; }
  .quote-headline {
    color: #fff;
    margin-bottom: 32px;
    line-height: 1.1;
  }
  .quote-form {
    background: #141414;
    padding: 40px;
    border-radius: 4px;
    margin-top: 16px;
    border-left: 4px solid var(--electric-yellow);
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
  }
  .form-fullwidth {
    display: block;
    margin-bottom: 24px;
  }
  .quote-form label {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .quote-form span {
    color: var(--steel);
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .quote-form input,
  .quote-form select,
  .quote-form textarea {
    background: #0a0a0a;
    border: 1px solid rgba(255,255,255,0.1);
    color: #fff;
    padding: 14px 16px;
    border-radius: 4px;
    font-family: inherit;
    font-size: 16px; /* prevent iOS zoom on focus; 16px is the iOS threshold */
    box-sizing: border-box;
    width: 100%;
    min-width: 0; /* lets the input shrink inside grid columns */
