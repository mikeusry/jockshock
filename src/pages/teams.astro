---
/**
 * /teams — JockShock + ZeroPoint gym program intake.
 *
 * Per the May 2026 gym-channel pivot (project_gym_channel_program memory):
 * this page sells the PAIRED program — JockShock for athletes' gear,
 * ZeroPoint for the facility — on monthly subscription with Fred as the
 * point of contact.
 *
 * Karin Lichey Usry pitched the gym channel as a one-line idea. Fred
 * Munzenmaier (UGA RB, D1 Training franchise owner, ex-Southland) runs it.
 * All form leads route to Fred via /api/teams-intake.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import StepBadge from "../components/StepBadge.astro";

const title = "JockShock for Gyms + Teams — A Program Built by Gym Owners, for Gym Owners";
const description =
  "JockShock for the athletes. ZeroPoint for the facility. Monthly subscription. Built by D1 athletes, run by a D1 Training franchise owner. Talk to Fred.";

const HERO_BG =
  "https://res.cloudinary.com/southland-organics/image/upload/c_fill,w_1800,h_1200,g_auto,q_auto,f_auto,dpr_auto/JockShock/beckham.jpg";
const PACK_6 =
  "https://res.cloudinary.com/southland-organics/image/upload/c_fit,w_700,q_auto,f_auto,dpr_auto/JockShock/jockshock-6pack-team-2026.png";
---

<BaseLayout title={title} description={description}>
  <div class="js-teams">
    {/* HERO — gym + facility framing */}
    <section class="teams-hero js-carbon">
      <div class="teams-hero-bg" style={`background-image: url('${HERO_BG}')`}></div>
      <div class="teams-hero-overlay"></div>
      <div class="teams-hero-grid">
        <div class="teams-hero-copy">
          <p class="eyebrow">For gym owners + athletic programs</p>
          <h1 class="teams-hero-headline">
            Two products.<br />One protocol.<br />Zero phone calls.
          </h1>
          <p class="teams-hero-sub">
            JockShock for the athletes' gear. ZeroPoint for your facility.
            Sold together on monthly subscription so you stop ordering
            and start training.
          </p>
          <div class="teams-hero-cta-row">
            <a href="#quote" class="cta-primary">Get a program quote</a>
            <a href="#program" class="cta-secondary">How it works</a>
          </div>
          <ul class="teams-hero-trust">
            <li>
              <span class="hero-trust-rule"></span>
              <div>
                <span class="hero-trust-label">Run by</span>
                <span class="hero-trust-detail">A Gym Owner</span>
              </div>
            </li>
            <li>
              <span class="hero-trust-rule"></span>
              <div>
                <span class="hero-trust-label">Built by</span>
                <span class="hero-trust-detail">D1 Athletes</span>
              </div>
            </li>
            <li>
              <span class="hero-trust-rule"></span>
              <div>
                <span class="hero-trust-label">Made in</span>
                <span class="hero-trust-detail">USA</span>
              </div>
            </li>
          </ul>
        </div>
        <div class="teams-hero-product">
          <img src={PACK_6} alt="JockShock 6-pack team pack" />
        </div>
      </div>
    </section>

    {/* THE PROGRAM — JockShock + ZeroPoint paired */}
    <section class="js-section js-fiber" id="program">
      <div class="js-section--inner">
        <p class="eyebrow">The program</p>
        <h2 class="program-headline">
          JockShock + ZeroPoint. Married chemistry, paired protocol.
        </h2>
        <p class="program-sub">
          Same chemistry family, two jobs. Together they cover everything
          from a hockey player's helmet to your locker-room mat to the
          rower in the corner. Sold together, one cadence, one invoice.
        </p>

        <div class="program-pair">
          <div class="program-card">
            <p class="program-card-eyebrow">For the athletes</p>
            <h3>JockShock</h3>
            <p class="program-card-tag">Goes home in the gear bag.</p>
            <ul class="program-card-list">
              <li>Pads, helmets, gloves, mouthguards</li>
              <li>Cleats, mats, shin guards, headgear</li>
              <li>Equipment that can't go in the wash</li>
              <li>32oz bottles, 6-pack team case</li>
            </ul>
          </div>
          <div class="program-pair-amp">
            <span>+</span>
          </div>
          <div class="program-card">
            <p class="program-card-eyebrow">For the facility</p>
            <h3>ZeroPoint</h3>
            <p class="program-card-tag">Stays in the facility.</p>
            <ul class="program-card-list">
              <li>Mats, equipment surfaces, shared gear</li>
              <li>Locker rooms, water bottle stations</li>
              <li>Cleaning protocols + facility hygiene</li>
              <li>Gallon, 2.5-gallon, 5-gallon pail</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    {/* SUBSCRIPTION — three steps with the hexagon-O badge */}
    <section class="js-section js-fiber routine-section subscription-section">
      <div class="js-section--inner">
        <p class="eyebrow">The subscription</p>
        <h2 class="program-headline">
          Stop reordering. Start training.
        </h2>
        <p class="program-sub">
          Gym owners hate calling to reorder. So we built the program around
          a subscription cadence — case of JockShock + case of ZeroPoint
          ships every month or every other month. ~10% off covers your
          shipping. Pause or cancel any time, no contract.
        </p>

        <ol class="subscription-steps">
          <li>
            <StepBadge number="1" tone="yellow" size={56} class="step-badge" />
            <h3>Pick your cadence</h3>
            <p>Monthly or bi-monthly. We'll size the case to your roster + spray frequency.</p>
          </li>
          <li>
            <StepBadge number="2" tone="yellow" size={56} class="step-badge" />
            <h3>It ships automatically</h3>
            <p>You get a heads-up email five days before each shipment. Skip a month, push it out, never lift a finger.</p>
          </li>
          <li>
            <StepBadge number="3" tone="yellow" size={56} class="step-badge" />
            <h3>Pause whenever</h3>
            <p>Off-season? Holiday? Pause it. No contract, no phone tag, no minimum commitment.</p>
          </li>
        </ol>
      </div>
    </section>

    {/* FRED — the program lead */}
    <section class="js-section js-carbon fred-section">
      <div class="js-section--inner fred-inner">
        <p class="eyebrow">Talk to Fred</p>
        <h2 class="fred-headline">
          A gym owner runs this program.<br />Because gym owners trust gym owners.
        </h2>
        <div class="fred-card">
          <div class="fred-detail">
            <p class="fred-name">Fred Munzenmaier</p>
            <p class="fred-creds">
              UGA Football, 2007–2009 · Running Back · #48
            </p>
            <p class="fred-creds">
              Owner — D1 Training franchise
            </p>
            <p class="fred-body">
              Fred wakes up in his gym every morning. He knows what the funk
              from a class of 20 athletes does to a mat by Friday. He knows
              what the equipment closet smells like in August. He runs this
              program because he wanted it to exist for his own gym first.
            </p>
            <a href="#quote" class="cta-primary">Get Fred your details</a>
          </div>
        </div>
      </div>
    </section>

    {/* WHO THIS IS FOR */}
    <section class="js-section js-fiber">
      <div class="js-section--inner">
        <p class="eyebrow">Who we work with</p>
        <h2 class="program-headline">If your roster shares gear or your athletes share a mat, this is for you.</h2>
        <ul class="who-list">
          <li>D1 Training franchises + functional fitness gyms</li>
          <li>CrossFit boxes + strength-and-conditioning gyms</li>
          <li>MMA, jiu-jitsu, and combat-sports gyms</li>
          <li>Boxing + wrestling rooms</li>
          <li>High school athletic programs (football, hockey, lacrosse, wrestling)</li>
          <li>Club + travel-team programs</li>
          <li>College athletic departments and club teams</li>
          <li>Cheerleading and tumbling facilities</li>
          <li>Athletic training facilities and PT clinics</li>
          <li>Recreation centers, YMCAs, municipal sports programs</li>
        </ul>
      </div>
    </section>

    {/* QUOTE FORM */}
    <section class="js-section js-carbon quote-section" id="quote">
      <div class="js-section--inner quote-inner">
        <p class="eyebrow">Request a quote</p>
        <h2 class="quote-headline">Tell Fred about your program.<br />He'll reply within one business day.</h2>

        <div class="quote-success" data-success hidden>
          <h3>Got it. Fred's on it.</h3>
          <p>
            Fred or someone from the team will email you within one business
            day with a quote tailored to your roster size and use case. If
            you need to chat sooner, give us a call at
            <a href="tel:8006083755">800-608-3755</a> and ask for Fred.
          </p>
        </div>

        <form class="quote-form" method="POST" action="/api/teams-intake" data-quote-form>
          <div class="form-row">
            <label>
              <span>Your name</span>
              <input type="text" name="name" required autocomplete="name" />
            </label>
            <label>
              <span>Role</span>
              <select name="role" required>
                <option value="">Select…</option>
                <option>Gym owner</option>
                <option>Head coach</option>
                <option>Assistant coach</option>
                <option>Athletic trainer (ATC)</option>
                <option>Club / program director</option>
                <option>Athletic director</option>
                <option>Equipment manager</option>
                <option>Other</option>
              </select>
            </label>
          </div>

          <div class="form-row">
            <label>
              <span>Gym / program / organization</span>
              <input type="text" name="organization" required autocomplete="organization" />
            </label>
            <label>
              <span>Email</span>
              <input type="email" name="email" required autocomplete="email" inputmode="email" />
            </label>
          </div>

          <div class="form-row">
            <label>
              <span>Phone (optional)</span>
              <input type="tel" name="phone" autocomplete="tel" inputmode="tel" />
            </label>
            <label>
              <span>Sport / discipline</span>
              <select name="sport" required>
                <option value="">Select…</option>
                <option>Functional fitness / D1 Training / CrossFit</option>
                <option>MMA / BJJ / combat sports</option>
                <option>Hockey</option>
                <option>Lacrosse</option>
                <option>Wrestling</option>
                <option>Football</option>
                <option>Soccer</option>
                <option>Multi-sport / general athletic</option>
                <option>Other</option>
              </select>
            </label>
          </div>

          <div class="form-row">
            <label>
              <span>Roster size (athletes per week)</span>
              <select name="roster_size" required>
                <option value="">Select…</option>
                <option>Under 25</option>
                <option>25–50</option>
                <option>50–100</option>
                <option>100–200</option>
                <option>200+</option>
              </select>
            </label>
            <label>
              <span>Decision timeline</span>
              <select name="timeline" required>
                <option value="">Select…</option>
                <option>This week (urgent)</option>
                <option>This month</option>
                <option>This quarter</option>
                <option>Next budget cycle</option>
                <option>Just exploring</option>
              </select>
            </label>
          </div>

          <label class="form-fullwidth">
            <span>What you're trying to solve (optional)</span>
            <textarea
              name="notes"
              rows="4"
              placeholder="Outbreak smell in the gym? Pre-season prep? Tired of reordering household sprays that don't work? Whatever the context — short answer is fine."
            ></textarea>
          </label>

          <input type="hidden" name="persona" value="carmen" />
          <input type="hidden" name="source" value="jockshock-teams-page" />

          <button type="submit" class="cta-primary cta-submit">Send the request</button>
          <p class="form-note">
            Goes to Fred Munzenmaier (program lead). Mike Usry is cc'd.
            No marketing spam, no auto-enrollment.
          </p>
        </form>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  // Stamp persona=carmen — gym/coach/facility surface always overrides default.
  import { setPersona } from "../utils/persona-stamp";
  setPersona("carmen");

  if (typeof window !== "undefined" && (window as any).pdPixel) {
    (window as any).pdPixel.track("teams_lander_view", {
      sub_brand: "jockshock",
      persona: "carmen",
      surface: "gym-program",
    });
  }

  const form = document.querySelector<HTMLFormElement>("[data-quote-form]");
  const successPanel = document.querySelector<HTMLElement>("[data-success]");
  const submitBtn = form?.querySelector<HTMLButtonElement>(".cta-submit");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form || !submitBtn) return;

    submitBtn.disabled = true;
    const originalLabel = submitBtn.textContent;
    submitBtn.textContent = "Sending…";

    const fd = new FormData(form);
    const payload = Object.fromEntries(fd.entries());

    if ((window as any).pdPixel) {
      (window as any).pdPixel.track("teams_quote_submitted", {
        sub_brand: "jockshock",
        persona: "carmen",
        sport: payload.sport,
        roster_size: payload.roster_size,
        timeline: payload.timeline,
        role: payload.role,
      });
    }

    try {
      const r = await fetch("/api/teams-intake", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });
      if (!r.ok) throw new Error(`Server returned ${r.status}`);
      form.hidden = true;
      if (successPanel) {
        successPanel.hidden = false;
        successPanel.scrollIntoView({ behavior: "smooth", block: "center" });
      }
    } catch (err) {
      console.error("[teams-intake] submit failed", err);
      submitBtn.disabled = false;
      submitBtn.textContent = originalLabel;
      let errorEl = form.querySelector<HTMLElement>(".form-error");
      if (!errorEl) {
        errorEl = document.createElement("p");
        errorEl.className = "form-error";
        submitBtn.insertAdjacentElement("afterend", errorEl);
      }
      errorEl.textContent =
        "Something went wrong sending that. Email Fred directly at fmunzjr@gmail.com and we'll handle it.";
    }
  });
</script>

<style>
  /* HERO ============================================================ */
  .teams-hero {
    position: relative;
    min-height: 78vh;
    overflow: hidden;
    padding: 0;
  }
  .teams-hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    z-index: 0;
  }
  .teams-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      120deg,
      rgba(10,10,10,0.94) 0%,
      rgba(10,10,10,0.74) 45%,
      rgba(10,10,10,0.45) 100%
    );
    z-index: 1;
  }
  .teams-hero-grid {
    position: relative;
    z-index: 2;
    max-width: 1400px;
    margin: 0 auto;
    padding: 96px 5% 80px;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 56px;
    align-items: center;
    min-height: 78vh;
  }
  .teams-hero-copy { max-width: 640px; }
  .teams-hero-headline {
    color: #fff;
    margin-bottom: 24px;
    line-height: 0.95;
  }
  .teams-hero-sub {
    font-size: 18px;
    line-height: 1.55;
    color: #d1d5db;
    margin-bottom: 32px;
    max-width: 520px;
  }
  .teams-hero-cta-row {
    display: flex;
    gap: 16px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }
  .teams-hero-trust {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 24px 36px;
    flex-wrap: wrap;
  }
  .teams-hero-trust li {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .teams-hero-product {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .teams-hero-product img {
    max-width: 100%;
    max-height: 540px;
    height: auto;
    width: auto;
    filter: drop-shadow(0 30px 60px rgba(0, 0, 0, 0.7));
  }

  /* SECTION SHARED =================================================== */
  .program-headline {
    margin-bottom: 16px;
  }
  .program-sub {
    font-size: 18px;
    line-height: 1.6;
    margin-bottom: 56px;
    max-width: 720px;
  }

  /* PAIRED PROGRAM ==================================================== */
  .program-pair {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 24px;
    align-items: center;
  }
  .program-card {
    background: #fff;
    border-left: 4px solid var(--electric-yellow);
    padding: 40px 36px;
    box-shadow: 0 2px 0 rgba(0,0,0,0.04), 0 12px 28px rgba(0,0,0,0.05);
  }
  .program-card-eyebrow {
    color: #b08e00;
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .program-card h3 {
    color: var(--ink);
    margin-bottom: 8px;
  }
  .program-card-tag {
    color: var(--graphite);
    font-size: 14px;
    margin-bottom: 24px;
    font-style: italic;
  }
  .program-card-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .program-card-list li {
    color: var(--ink);
    font-size: 15px;
    line-height: 1.5;
    padding: 8px 0 8px 24px;
    position: relative;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }
  .program-card-list li:last-child { border-bottom: none; }
  .program-card-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 17px;
    width: 8px;
    height: 8px;
