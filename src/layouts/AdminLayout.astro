---
/**
 * JockShock admin shell. Lift-and-adapt from southland-platform's
 * AdminLayout.astro pattern: client-side password gate, sessionStorage
 * auth flag, robots noindex. Single shared password (no user table).
 *
 * NOT for sensitive data. The password lives in JS source — anyone
 * who views-source can read it. Acceptable for: founder commission
 * pages, internal cheat sheets, things Mike would print and hand
 * someone in person anyway. NOT acceptable for: customer PII,
 * financial reports tied to specific people, anything that would
 * matter if a bot scraped it.
 *
 * If we ever need real auth, swap this for Supabase Auth + magic link
 * (the southland-inventory pattern) — but don't do that for v1.
 */
interface NavItem {
  name: string;
  href: string;
}

interface Props {
  title: string;
  activeNav?: string;
  navItems?: NavItem[];
}

const defaultNav: NavItem[] = [
  { name: "Overview", href: "/admin/" },
  { name: "Fred — Founder Plan", href: "/admin/fred/" },
];

const { title, activeNav, navItems = defaultNav } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | JockShock Admin</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      :root {
        --bg: #0d0d0d;
        --surface: #1a1a1a;
        --surface-2: #242424;
        --border: #2a2a2a;
        --text: #f5f5f5;
        --text-secondary: #a0a0a0;
        --accent: #ffd54a;
        --accent-dark: #e6bf3f;
        --error: #ef4444;
        --radius: 8px;
        --radius-sm: 4px;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html,
      body {
        background: var(--bg);
        color: var(--text);
        font-family:
          -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
        font-size: 15px;
        line-height: 1.55;
        min-height: 100vh;
      }

      a {
        color: var(--accent);
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      .admin-layout {
        display: grid;
        grid-template-columns: 240px 1fr;
        min-height: 100vh;
      }

      .admin-sidebar {
        background: var(--surface);
        border-right: 1px solid var(--border);
        position: sticky;
        top: 0;
        height: 100vh;
        display: flex;
        flex-direction: column;
      }

      .sidebar-header {
        padding: 20px 20px 16px;
        border-bottom: 1px solid var(--border);
      }

      .sidebar-logo {
        font-weight: 700;
        font-size: 16px;
        letter-spacing: 0.04em;
        color: var(--accent);
      }

      .sidebar-title {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        color: var(--text-secondary);
        margin-top: 4px;
      }

      .sidebar-nav {
        padding: 12px;
        flex: 1;
      }

      .nav-item {
        display: block;
        padding: 9px 12px;
        border-radius: var(--radius-sm);
        font-size: 14px;
        color: var(--text);
        margin-bottom: 2px;
      }

      .nav-item:hover {
        background: var(--surface-2);
        text-decoration: none;
      }

      .nav-item.active {
        background: var(--surface-2);
        color: var(--accent);
        font-weight: 600;
      }

      .sidebar-footer {
        padding: 16px 20px;
        border-top: 1px solid var(--border);
      }

      .back-link {
        font-size: 13px;
        color: var(--text-secondary);
      }

      .back-link:hover {
        color: var(--text);
      }

      .admin-main {
        padding: 32px 40px 80px;
        max-width: 980px;
        width: 100%;
      }

      /* Password gate */
      .password-gate {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
      }

      .password-form {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 32px;
        width: 100%;
        max-width: 360px;
      }

      .password-form .brand {
        font-weight: 700;
        font-size: 14px;
        letter-spacing: 0.06em;
        color: var(--accent);
        text-transform: uppercase;
        margin-bottom: 4px;
      }

      .password-form h1 {
        font-size: 20px;
        font-weight: 600;
        color: var(--text);
        margin-bottom: 6px;
      }

      .password-form p {
        font-size: 14px;
        color: var(--text-secondary);
        margin-bottom: 20px;
      }

      .password-form input {
        width: 100%;
        padding: 11px 12px;
        background: var(--bg);
        color: var(--text);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        font: inherit;
        font-size: 14px;
        margin-bottom: 12px;
      }

      .password-form input:focus {
        outline: none;
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(255, 213, 74, 0.15);
      }

      .password-form button {
        width: 100%;
        padding: 11px 16px;
        background: var(--accent);
        color: var(--bg);
        border: none;
        border-radius: var(--radius-sm);
        font: inherit;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .password-form button:hover {
        background: var(--accent-dark);
      }

      .password-error {
        color: var(--error);
        font-size: 13px;
        margin-bottom: 12px;
        display: none;
      }

      @media (max-width: 900px) {
        .admin-layout {
          grid-template-columns: 1fr;
        }

        .admin-sidebar {
          position: relative;
          height: auto;
          border-right: none;
          border-bottom: 1px solid var(--border);
        }

        .admin-main {
          padding: 24px 20px 60px;
        }
      }
    </style>
  </head>
  <body>
    <!-- Password gate -->
    <div id="password-gate" class="password-gate" style="display: none;">
      <form class="password-form" id="auth-form">
        <div class="brand">JockShock</div>
        <h1>Admin Access</h1>
        <p>Enter the admin password to continue.</p>
        <div id="password-error" class="password-error">Incorrect password.</div>
        <input
          type="password"
          id="admin-password"
          placeholder="Password"
          autocomplete="current-password"
          autofocus
        />
        <button type="submit">Enter</button>
      </form>
    </div>

    <!-- Admin shell -->
    <div id="admin-content" class="admin-layout">
      <aside class="admin-sidebar">
        <div class="sidebar-header">
          <div class="sidebar-logo">JockShock</div>
          <div class="sidebar-title">Admin</div>
        </div>

        <nav class="sidebar-nav">
          {
            navItems.map((item) => (
              <a
                href={item.href}
                class={`nav-item ${activeNav === item.href ? "active" : ""}`}
              >
                {item.name}
              </a>
            ))
          }
        </nav>

        <div class="sidebar-footer">
          <a href="/" class="back-link">← Back to public site</a>
        </div>
      </aside>

      <main class="admin-main">
        <slot />
      </main>
    </div>

    <script is:inline>
      const ADMIN_PASSWORD = "Munzy2026!";
      const AUTH_KEY = "jockshock_admin_auth";

      function checkAuth() {
        return sessionStorage.getItem(AUTH_KEY) === "authenticated";
      }

      function showGate() {
        document.getElementById("password-gate").style.display = "flex";
        document.getElementById("admin-content").style.display = "none";
      }

      function showContent() {
        document.getElementById("password-gate").style.display = "none";
        document.getElementById("admin-content").style.display = "grid";
      }

      if (checkAuth()) {
        showContent();
      } else {
        showGate();
      }

      document
        .getElementById("auth-form")
        .addEventListener("submit", function (e) {
          e.preventDefault();
          const input = document.getElementById("admin-password");
          if (input.value === ADMIN_PASSWORD) {
            sessionStorage.setItem(AUTH_KEY, "authenticated");
            showContent();
          } else {
            document.getElementById("password-error").style.display = "block";
            input.value = "";
            input.focus();
          }
        });
    </script>
  </body>
</html>
