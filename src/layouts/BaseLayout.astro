---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CartDrawer from "../components/CartDrawer.svelte";
import AnnouncementBar from "../components/AnnouncementBar.astro";

export interface Props {
  title: string;
  description?: string;
  /** Absolute or root-relative URL to the social-share image. Defaults to the
   *  JockShock single-bottle hero on Cloudinary. */
  ogImage?: string;
  /** Override the og:type. Default 'website'; set to 'product' on PDP. */
  ogType?: "website" | "product";
}

const SITE_URL = "https://jockshock.com";
const DEFAULT_DESC =
  "Pro-grade equipment deodorizer for serious athletes. Built for gear, not for the kitchen. Powered by ZeroPoint Technology.";
const DEFAULT_OG_IMAGE =
  "https://res.cloudinary.com/southland-organics/image/upload/c_fit,w_1200,h_630,b_rgb:0a0a0a,q_auto,f_jpg/JockShock/jockshock-32oz-single-2026.png";

const {
  title,
  description = DEFAULT_DESC,
  ogImage = DEFAULT_OG_IMAGE,
  ogType = "website",
} = Astro.props as Props;

// Canonical URL — strip query string, normalize trailing slash.
const canonicalPath = Astro.url.pathname;
const canonicalUrl = `${SITE_URL}${canonicalPath}`;

// point.dog pixel config — JockShock events land in the Southland CDP table.
// Per legal-entity decision (project_jockshock_legal_entity), JockShock is a
// brand inside Southland Organics and rolls up to Southland P&L. Using
// brandId=southland keeps JockShock traffic in the same CDP namespace as the
// rest of Southland; JockShock-specific slicing happens via page/URL tagging
// at event time, not at the pixel level.
const pixelBrandId = import.meta.env.PUBLIC_PIXEL_BRAND_ID || "southland";
const pixelEndpoint =
  import.meta.env.PUBLIC_PIXEL_ENDPOINT || "https://pixel.southlandorganics.com/collect";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph (Facebook, LinkedIn, iMessage, Slack, generic crawlers) -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="JockShock" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="JockShock — pro-grade equipment deodorizer" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="JockShock — pro-grade equipment deodorizer" />

    <!-- point.dog Pixel -->
    <script is:inline define:vars={{ pixelBrandId, pixelEndpoint }}>
      window.pdPixelConfig = {
        brandId: pixelBrandId,
        endpoint: pixelEndpoint,
        // Tag every event from this site as JockShock so we can slice in CDP
        // even though we share the Southland brand_id namespace.
        defaultProperties: { sub_brand: "jockshock" },
      };
    </script>
    <script is:inline src="https://cdn.point.dog/pixel/pd-pixel.min.js" async></script>

    <style is:global>
      @import "../styles/global.css";
    </style>
  </head>
  <body>
    <AnnouncementBar />
    <CartDrawer client:idle />
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
