---
/**
 * Hexagon-with-lightning-bolt step badge — the JockShock "O" mark
 * adapted as a numbered process indicator.
 *
 * Geometry: hexagon body fills the badge, lightning bolt cuts a notch
 * from upper-right (negative space — the bolt is the BG color showing
 * through), digit sits centered and dominant.
 */
interface Props {
  number: number | string;
  /** Color tone — "yellow" for light backgrounds, "dark" for inverted */
  tone?: "yellow" | "dark";
  /** Pixel size of the hexagon (height) */
  size?: number;
  class?: string;
}

const {
  number,
  tone = "yellow",
  size = 64,
  class: extraClass = "",
} = Astro.props as Props;

const fill = tone === "yellow" ? "#FFE500" : "#0a0a0a";
const ink = tone === "yellow" ? "#0a0a0a" : "#FFE500";

// Flat-top hexagon — width:height ratio for regular hex is 1.155:1
const w = Math.round(size * 1.155);
const h = size;
---

<div class={`js-step-badge ${extraClass}`} style={`--js-step-size:${h}px;width:${w}px;height:${h}px`}>
  <svg
    viewBox="0 0 100 87"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
    class="js-step-badge__svg"
  >
    {/* Hexagon body */}
    <polygon
      points="25,2 75,2 98,43.5 75,85 25,85 2,43.5"
      fill={fill}
    />

    {/* Lightning bolt — small accent in the upper-right corner only,
        tinted slightly with ink color so it reads as the JockShock O
        mark without covering the digit space. */}
    <polygon
      points="78,8 64,32 73,32 70,52 84,28 75,28 80,8"
      fill={ink}
      opacity="0.85"
    />
  </svg>

  <span class="js-step-badge__num" style={`color:${ink}`}>{number}</span>
</div>

<style>
  .js-step-badge {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  /* SVG sits at z-index 0 so the digit (z-index 2) always wins. */
  .js-step-badge__svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.18));
  }
  .js-step-badge__num {
    position: relative;
    z-index: 2;
    font-family: 'Bebas Neue', 'Impact', sans-serif;
    font-size: calc(var(--js-step-size, 64px) * 0.6);
    line-height: 1;
    /* Slight left-bias so the digit sits in the visual center of the
       hexagon (which has more weight on the right because of the bolt). */
    transform: translate(-3px, 1px);
  }
</style>
