---
const year = new Date().getFullYear();
---

<footer class="js-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <img src="/JockShock_Logo.png" alt="JockShock" class="footer-logo" width="180" height="50" />
      <p class="footer-tagline">Performance Protection for Serious Athletes.</p>
      <p class="footer-zeropoint">Powered by ZeroPoint Technology · Made in USA</p>
    </div>

    <nav class="footer-nav" aria-label="Footer">
      <div class="footer-col">
        <h4>Shop</h4>
        <ul>
          <li><a href="/products/jockshock/">JockShock 32oz</a></li>
          <li><a href="/products/jockshock/">Athlete Pack (3)</a></li>
          <li><a href="/products/jockshock/">Team Pack (6)</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>For You</h4>
        <ul>
          <li><a href="/parents/">Sports parents</a></li>
          <li><a href="/teams/">Coaches &amp; teams</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Support</h4>
        <ul>
          <li><a href="mailto:mike@southlandorganics.com">Contact</a></li>
          <li><a href="tel:8006083755">800-608-3755</a></li>
          <li><a href="/teams/">Wholesale &amp; teams</a></li>
        </ul>
      </div>
    </nav>
  </div>

  <div class="footer-bar">
    <div class="footer-bar-inner">
      <p>&copy; {year} JockShock. A Southland Organics brand.</p>
      <p class="footer-bar-address">189 Luke Road, Bogart, GA 30622</p>
    </div>
  </div>
</footer>

<style>
  .js-footer {
    background: #0a0a0a;
    color: #9ca3af;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
  }

  .footer-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 64px 5% 48px;
    display: grid;
    grid-template-columns: 1.2fr 2fr;
    gap: 64px;
  }

  .footer-brand .footer-logo {
    height: 36px;
    width: auto;
    margin-bottom: 16px;
  }
  .footer-tagline {
    color: #f3f4f6;
    font-weight: 700;
    font-size: 0.875rem;
    margin: 0 0 8px;
  }
  .footer-zeropoint {
    color: #6b7280;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
  }

  .footer-nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  .footer-col h4 {
    color: #facc15;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0 0 16px;
  }
  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .footer-col a {
    color: #d1d5db;
    text-decoration: none;
    font-size: 0.875rem;
    transition: color 0.15s ease;
  }
  .footer-col a:hover {
    color: #facc15;
  }

  .footer-bar {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    background: #050505;
  }
  .footer-bar-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 20px 5%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
  }
  .footer-bar p {
    margin: 0;
    color: #6b7280;
    font-size: 0.75rem;
  }
  .footer-bar-address {
    text-align: right;
  }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 48px 5% 32px;
    }
    .footer-nav {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }
    .footer-bar-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 4px;
    }
    .footer-bar-address {
      text-align: left;
    }
  }
</style>
