PUBLIC_SHOPIFY_SHOP={your-store}.myshopify.com
PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
PRIVATE_SHOPIFY_STOREFRONT_ACCESS_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Cloudinary (image hosting)
PUBLIC_CLOUDINARY_CLOUD_NAME=southland-organics
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# point.dog pixel — keep brandId=southland so JockShock events land in the
# Southland CDP namespace (JockShock is a Southland sub-brand). Sub-brand
# tagging happens at event time via defaultProperties.sub_brand=jockshock
# in BaseLayout.astro.
PUBLIC_PIXEL_BRAND_ID=southland
PUBLIC_PIXEL_ENDPOINT=https://pixel.southlandorganics.com/collect

# SendGrid — powers /api/teams-intake (Carmen B2B form). Same Southland
# account as southland-platform; safe to share since JockShock is a
# Southland sub-brand.
SENDGRID_API_KEY=

# Klaviyo — powers /api/lead-magnet (Gear Smell Field Guide footer form).
# Same key also powers /api/cart-event (server-side bridge to Klaviyo's
# Events API, used to fire Viewed Product / Added to Cart / Viewed Cart /
# Started Checkout for the abandon-cart flow when sl_email cookie is set).
# Shared with Southland Klaviyo account. Required for prod.
KLAVIYO_PRIVATE_API_KEY=
KLAVIYO_LEAD_MAGNET_LIST_ID=

# Nexus lead ingest — powers /api/teams-intake v2 (T-652). When both are set,
# successful teams-intake submissions also POST to Nexus /api/leads/ingest so
# the lead lands in the Nexus pipeline (dedup, scoring, assignment to Fred,
# Klaviyo `Lead Created` event for the carmen B2B flow trigger). Optional —
# SendGrid email is the source-of-truth; Nexus is bonus tracking.
NEXUS_INGEST_URL=https://nexus.southlandorganics.com
NEXUS_INGEST_API_KEY=